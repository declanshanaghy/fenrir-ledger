{
  "name": "odin-throne-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && node --input-type=module --eval 'import(\"./src/index.ts\")'",
    "start": "node dist/index.js",
    "compile": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm run verify:tsc",
    "verify:tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@kubernetes/client-node": "^1.0.0",
    "hono": "^4.6.20",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "vitest": {
    "include": ["src/__tests__/**/*.test.ts"],
    "environment": "node"
  }
}
