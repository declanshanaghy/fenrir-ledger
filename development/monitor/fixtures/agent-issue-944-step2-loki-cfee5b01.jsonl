{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T4RjbpNXweLby9khs8r42J","type":"tool_result","content":"     1→/**\n     2→ * Unit tests for lib/kv/trial-store.ts\n     3→ *\n     4→ * Loki QA augmentation — covers gaps not tested by the route-level integration\n     5→ * tests: pure computeTrialStatus boundary logic and Redis key / TTL contract.\n     6→ *\n     7→ * Acceptance criteria targeted:\n     8→ *  - AC1 (#944): trial is created on first sign-in (keepalive fix + auto-init)\n     9→ *  - AC2 (#944): computeTrialStatus correctly transitions active → expired at the\n    10→ *    30-day boundary so the auto-init fallback in /api/trial/status returns the\n    11→ *    right state\n    12→ *  - AC3 (#944): convertedDate overrides expiry (Stripe-converted users stay \"converted\")\n    13→ *  - Redis key format and TTL are stable (regression guard against key drift)\n    14→ *\n    15→ * FiremanDecko already tests the route handlers end-to-end. These tests exercise\n    16→ * computeTrialStatus and initTrial as pure unit-level contracts.\n    17→ *\n    18→ * @see src/lib/kv/trial-store.ts\n    19→ * @ref Issue #944 (regression of #922)\n    20→ */\n    21→\n    22→import { describe, it, expect, beforeEach, vi } from \"vitest\";\n    23→\n    24→// ── Mocks ─────────────────────────────────────────────────────────────────────\n    25→\n    26→const mockRedis = vi.hoisted(() => ({\n    27→  get: vi.fn(),\n    28→  set: vi.fn(),\n    29→}));\n    30→\n    31→vi.mock(\"@/lib/kv/redis-client\", () => ({\n    32→  getRedisClient: () => mockRedis,\n    33→}));\n    34→\n    35→vi.mock(\"@/lib/logger\", () => ({\n    36→  log: { debug: vi.fn(), info: vi.fn(), warn: vi.fn(), error: vi.fn() },\n    37→}));\n    38→\n    39→// ── Import after mocks ─────────────────────────────────────────────────────────\n    40→\n    41→import { computeTrialStatus, initTrial, getTrial } from \"@/lib/kv/trial-store\";\n    42→import { TRIAL_DURATION_DAYS } from \"@/lib/trial-utils\";\n    43→\n    44→// ── Helpers ───────────────────────────────────────────────────────────────────\n    45→\n    46→const VALID_FINGERPRINT = \"b\".repeat(64);\n    47→\n    48→/** Returns an ISO date exactly N days ago (ms-precise). */\n    49→function daysAgo(n: number): string {\n    50→  const d = new Date(Date.now() - n * 24 * 60 * 60 * 1000);\n    51→  return d.toISOString();\n    52→}\n    53→\n    54→// ── computeTrialStatus — pure logic, no I/O ────────────────────────────────────\n    55→\n    56→describe(\"computeTrialStatus — boundary conditions (#944 AC2)\", () => {\n    57→  it(\"returns status:none when trial is null (no record in Redis)\", () => {\n    58→    const result = computeTrialStatus(null);\n    59→    expect(result.status).toBe(\"none\");\n    60→    expect(result.remainingDays).toBe(0);\n    61→  });\n    62→\n    63→  it(`returns active with 1 remaining day when exactly ${TRIAL_DURATION_DAYS - 1} days have elapsed`, () => {\n    64→    const startDate = daysAgo(TRIAL_DURATION_DAYS - 1); // day 29\n    65→    const result = computeTrialStatus({ startDate });\n    66→    expect(result.status).toBe(\"active\");\n    67→    expect(result.remainingDays).toBe(1);\n    68→  });\n    69→\n    70→  it(`returns expired with 0 days when exactly ${TRIAL_DURATION_DAYS} days have elapsed`, () => {\n    71→    const startDate = daysAgo(TRIAL_DURATION_DAYS); // day 30 — trial is over\n    72→    const result = computeTrialStatus({ startDate });\n    73→    expect(result.status).toBe(\"expired\");\n    74→    expect(result.remainingDays).toBe(0);\n    75→  });\n    76→\n    77→  it(\"returns converted (overriding expiry) when convertedDate is set (#944 AC3)\", () => {\n    78→    // User converted on day 10, then trial would have expired — status must stay \"converted\"\n    79→    const startDate = daysAgo(TRIAL_DURATION_DAYS + 5); // well past expiry\n    80→    const convertedDate = daysAgo(TRIAL_DURATION_DAYS - 20);\n    81→    const result = computeTrialStatus({ startDate, convertedDate });\n    82→    expect(result.status).toBe(\"converted\");\n    83→    expect(result.remainingDays).toBe(0);\n    84→    expect(result.convertedDate).toBe(convertedDate);\n    85→  });\n    86→});\n    87→\n    88→// ── initTrial — Redis key and TTL contract ────────────────────────────────────\n    89→\n    90→describe(\"initTrial — Redis key format and TTL (#944 AC1)\", () => {\n    91→  beforeEach(() => {\n    92→    vi.clearAllMocks();\n    93→  });\n    94→\n    95→  it(\"writes trial under key `trial:{fingerprint}` with TTL 5184000 s (60 days)\", async () => {\n    96→    mockRedis.get.mockResolvedValueOnce(null); // no existing trial\n    97→    mockRedis.set.mockResolvedValueOnce(\"OK\");\n    98→\n    99→    await initTrial(VALID_FINGERPRINT);\n   100→\n   101→    expect(mockRedis.set).toHaveBeenCalledOnce();\n   102→    const [key, , exFlag, ttl] = mockRedis.set.mock.calls[0] as [string, string, string, number];\n   103→    expect(key).toBe(`trial:${VALID_FINGERPRINT}`);\n   104→    expect(exFlag).toBe(\"EX\");\n   105→    // 60 days × 24 h × 60 min × 60 s = 5 184 000 s\n   106→    expect(ttl).toBe(60 * 24 * 60 * 60);\n   107→  });\n   108→});\n   109→\n   110→// ── getTrial — malformed Redis value ──────────────────────────────────────────\n   111→\n   112→describe(\"getTrial — error handling\", () => {\n   113→  beforeEach(() => {\n   114→    vi.clearAllMocks();\n   115→  });\n   116→\n   117→  it(\"returns null (not throws) when Redis contains malformed JSON\", async () => {\n   118→    mockRedis.get.mockResolvedValueOnce(\"not-valid-json{{{\");\n   119→\n   120→    // getTrial should catch the parse error and return null\n   121→    const result = await getTrial(VALID_FINGERPRINT);\n   122→    expect(result).toBeNull();\n   123→  });\n   124→});\n   125→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8704cb95-a276-4615-86f1-ec7832e348ff","uuid":"b1a6f528-e11c-4a0b-ac22-eb982952060b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/repo/development/frontend/src/__tests__/trial/trial-store.test.ts","content":"/**\n * Unit tests for lib/kv/trial-store.ts\n *\n * Loki QA augmentation — covers gaps not tested by the route-level integration\n * tests: pure computeTrialStatus boundary logic and Redis key / TTL contract.\n *\n * Acceptance criteria targeted:\n *  - AC1 (#944): trial is created on first sign-in (keepalive fix + auto-init)\n *  - AC2 (#944): computeTrialStatus correctly transitions active → expired at the\n *    30-day boundary so the auto-init fallback in /api/trial/status returns the\n *    right state\n *  - AC3 (#944): convertedDate overrides expiry (Stripe-converted users stay \"converted\")\n *  - Redis key format and TTL are stable (regression guard against key drift)\n *\n * FiremanDecko already tests the route handlers end-to-end. These tests exercise\n * computeTrialStatus and initTrial as pure unit-level contracts.\n *\n * @see src/lib/kv/trial-store.ts\n * @ref Issue #944 (regression of #922)\n */\n\nimport { describe, it, expect, beforeEach, vi } from \"vitest\";\n\n// ── Mocks ─────────────────────────────────────────────────────────────────────\n\nconst mockRedis = vi.hoisted(() => ({\n  get: vi.fn(),\n  set: vi.fn(),\n}));\n\nvi.mock(\"@/lib/kv/redis-client\", () => ({\n  getRedisClient: () => mockRedis,\n}));\n\nvi.mock(\"@/lib/logger\", () => ({\n  log: { debug: vi.fn(), info: vi.fn(), warn: vi.fn(), error: vi.fn() },\n}));\n\n// ── Import after mocks ─────────────────────────────────────────────────────────\n\nimport { computeTrialStatus, initTrial, getTrial } from \"@/lib/kv/trial-store\";\nimport { TRIAL_DURATION_DAYS } from \"@/lib/trial-utils\";\n\n// ── Helpers ───────────────────────────────────────────────────────────────────\n\nconst VALID_FINGERPRINT = \"b\".repeat(64);\n\n/** Returns an ISO date exactly N days ago (ms-precise). */\nfunction daysAgo(n: number): string {\n  const d = new Date(Date.now() - n * 24 * 60 * 60 * 1000);\n  return d.toISOString();\n}\n\n// ── computeTrialStatus — pure logic, no I/O ────────────────────────────────────\n\ndescribe(\"computeTrialStatus — boundary conditions (#944 AC2)\", () => {\n  it(\"returns status:none when trial is null (no record in Redis)\", () => {\n    const result = computeTrialStatus(null);\n    expect(result.status).toBe(\"none\");\n    expect(result.remainingDays).toBe(0);\n  });\n\n  it(`returns active with 1 remaining day when exactly ${TRIAL_DURATION_DAYS - 1} days have elapsed`, () => {\n    const startDate = daysAgo(TRIAL_DURATION_DAYS - 1); // day 29\n    const result = computeTrialStatus({ startDate });\n    expect(result.status).toBe(\"active\");\n    expect(result.remainingDays).toBe(1);\n  });\n\n  it(`returns expired with 0 days when exactly ${TRIAL_DURATION_DAYS} days have elapsed`, () => {\n    const startDate = daysAgo(TRIAL_DURATION_DAYS); // day 30 — trial is over\n    const result = computeTrialStatus({ startDate });\n    expect(result.status).toBe(\"expired\");\n    expect(result.remainingDays).toBe(0);\n  });\n\n  it(\"returns converted (overriding expiry) when convertedDate is set (#944 AC3)\", () => {\n    // User converted on day 10, then trial would have expired — status must stay \"converted\"\n    const startDate = daysAgo(TRIAL_DURATION_DAYS + 5); // well past expiry\n    const convertedDate = daysAgo(TRIAL_DURATION_DAYS - 20);\n    const result = computeTrialStatus({ startDate, convertedDate });\n    expect(result.status).toBe(\"converted\");\n    expect(result.remainingDays).toBe(0);\n    expect(result.convertedDate).toBe(convertedDate);\n  });\n});\n\n// ── initTrial — Redis key and TTL contract ────────────────────────────────────\n\ndescribe(\"initTrial — Redis key format and TTL (#944 AC1)\", () => {\n  beforeEach(() => {\n    vi.clearAllMocks();\n  });\n\n  it(\"writes trial under key `trial:{fingerprint}` with TTL 5184000 s (60 days)\", async () => {\n    mockRedis.get.mockResolvedValueOnce(null); // no existing trial\n    mockRedis.set.mockResolvedValueOnce(\"OK\");\n\n    await initTrial(VALID_FINGERPRINT);\n\n    expect(mockRedis.set).toHaveBeenCalledOnce();\n    const [key, , exFlag, ttl] = mockRedis.set.mock.calls[0] as [string, string, string, number];\n    expect(key).toBe(`trial:${VALID_FINGERPRINT}`);\n    expect(exFlag).toBe(\"EX\");\n    // 60 days × 24 h × 60 min × 60 s = 5 184 000 s\n    expect(ttl).toBe(60 * 24 * 60 * 60);\n  });\n});\n\n// ── getTrial — malformed Redis value ──────────────────────────────────────────\n\ndescribe(\"getTrial — error handling\", () => {\n  beforeEach(() => {\n    vi.clearAllMocks();\n  });\n\n  it(\"returns null (not throws) when Redis contains malformed JSON\", async () => {\n    mockRedis.get.mockResolvedValueOnce(\"not-valid-json{{{\");\n\n    // getTrial should catch the parse error and return null\n    const result = await getTrial(VALID_FINGERPRINT);\n    expect(result).toBeNull();\n  });\n});\n","numLines":125,"startLine":1,"totalLines":125}}}
