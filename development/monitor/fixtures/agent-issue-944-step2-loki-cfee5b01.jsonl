const claims = decodeIdToken(tokens.id_token);\n   181→\n   182→        const session: FenrirSession = {\n   183→          access_token: tokens.access_token,\n   184→          id_token: tokens.id_token,\n   185→          ...(tokens.refresh_token ? { refresh_token: tokens.refresh_token } : {}),\n   186→          expires_at: Date.now() + tokens.expires_in * 1000,\n   187→          user: {\n   188→            sub: claims.sub,\n   189→            email: claims.email,\n   190→            name: claims.name,\n   191→            picture: claims.picture,\n   192→          },\n   193→        };\n   194→\n   195→        setSession(session);\n   196→\n   197→        // Fire-and-forget trial init on first sign-in (#922 / #944).\n   198→        // Idempotent — if a trial already exists for this fingerprint it is preserved.\n   199→        // keepalive:true ensures the request completes even after window.location.replace()\n   200→        // navigates away — without it the browser aborts in-flight requests on navigation\n   201→        // (regression root cause for #944).\n   202→        void (async () => {\n   203→          try {\n   204→            const fingerprint = await computeFingerprint();\n   205→            if (isValidFingerprint(fingerprint)) {\n   206→              await fetch(\"/api/trial/init\", {\n   207→                method: \"POST\",\n   208→                headers: {\n   209→                  \"Content-Type\": \"application/json\",\n   210→                  Authorization: `Bearer ${tokens.id_token}`,\n   211→                },\n   212→                body: JSON.stringify({ fingerprint }),\n   213→                keepalive: true,\n   214→              });\n   215→              // Clear cached trial status so the next useTrialStatus fetch is fresh.\n   216→              clearTrialStatusCache();\n   217→            }\n   218→          } catch {\n   219→            // Non-fatal — trial will be auto-initialized on first /api/trial/status call.\n   220→          }\n   221→        })();\n   222→\n   223→        // Clean up PKCE transient data only after successful exchange.\n   224→        sessionStorage.removeItem(PKCE_SESSION_KEY);\n   225→\n   226→        // Silent merge: carry anonymous cards into the Google household\n   227→        const { getAnonHouseholdId } = await import(\"@/lib/auth/household\");\n   228→        const { mergeAnonymousCards, isMergeComplete } = await import(\"@/lib/merge-anonymous\");\n   229→\n   230→        const anonId = getAnonHouseholdId();\n   231→        if (anonId && !isMergeComplete(anonId)) {\n   232→          const result = mergeAnonymousCards(session.user.sub, anonId);\n   233→          if (result.merged > 0) {\n   234→            sessionStorage.setItem(\"fenrir:merge-result\", JSON.stringify(result));\n   235→          }\n   236→        }\n   237→\n   238→        // Don't show the success state - keep the exchanging state visible\n   239→        // until redirect completes to avoid rapid visual transitions.\n   240→        // The success state would only flash briefly before redirect anyway.\n   241→\n   242→        // Redirect to the original destination (with security validation).\n   243→        // validateReturnTo ensures relative paths only — no open redirects.\n   244→        const destination = validateReturnTo(pkceData.callbackUrl);\n   245→\n   246→        // Use replace instead of href to prevent back button issues\n   247→        window.location.replace(destination);\n   248→      } catch (err) {\n   249→        const message = err instanceof Error ? err.message : String(err);\n   250→        console.error(\"[Fenrir] Auth callback error:\", message);\n   251→        // Only update state if component is still mounted\n   252→        if (isMountedRef.current) {\n   253→          setErrorMessage(message);\n   254→          setCallbackStatus(\"error\");\n   255→        }\n   256→      }\n   257→    }\n   258→\n   259→    exchangeCode();\n   260→    // Run only once on mount — search