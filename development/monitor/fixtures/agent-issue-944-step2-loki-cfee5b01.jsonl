{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HYt4eV3ryAiG2mZQUnsHdQ","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→/**\n     4→ * Auth Callback Page — /ledger/auth/callback\n     5→ *\n     6→ * Handles the redirect from Google's OAuth2 consent screen.\n     7→ * Expected URL params: ?code=<auth_code>&state=<csrf_state>\n     8→ *\n     9→ * Flow:\n    10→ *  1. Read { verifier, state, callbackUrl } from sessionStorage.\n    11→ *  2. Verify the state param matches to prevent CSRF.\n    12→ *  3. POST to /api/auth/token (server proxy) with code + code_verifier (PKCE).\n    13→ *     The server proxy forwards the request to Google with the client_secret,\n    14→ *     keeping the secret off the browser. The browser still owns the full\n    15→ *     PKCE flow (verifier, challenge, state).\n    16→ *  4. Decode the id_token JWT payload (base64url middle segment).\n    17→ *  5. Build a FenrirSession and write it to localStorage(\"fenrir:auth\").\n    18→ *  6. Redirect to callbackUrl (default: /).\n    19→ *\n    20→ * See ADR-005 for the auth architecture decision.\n    21→ */\n    22→\n    23→import { useEffect, useState, useRef, Suspense } from \"react\";\n    24→import { useSearchParams } from \"next/navigation\";\n    25→import { setSession } from \"@/lib/auth/session\";\n    26→import { validateReturnTo } from \"@/lib/auth/sign-in-url\";\n    27→import { computeFingerprint, isValidFingerprint } from \"@/lib/trial-utils\";\n    28→import { clearTrialStatusCache } from \"@/hooks/useTrialStatus\";\n    29→import type { FenrirSession } from \"@/lib/types\";\n    30→\n    31→/** sessionStorage key written by /sign-in */\n    32→const PKCE_SESSION_KEY = \"fenrir:pkce\";\n    33→\n    34→/** Server-side token exchange proxy — keeps client_secret off the browser. */\n    35→const TOKEN_PROXY_URL = \"/api/auth/token\";\n    36→\n    37→// ── id_token decoder ──────────────────────────────────────────────────────────\n    38→\n    39→interface IdTokenClaims {\n    40→  sub: string;\n    41→  email: string;\n    42→  name: string;\n    43→  picture: string;\n    44→  exp: number;\n    45→}\n    46→\n    47→/**\n    48→ * Decodes the payload of a JWT without verifying the signature.\n    49→ * Safe here because the token was received directly from Google's token\n    50→ * endpoint over HTTPS and the exchange was PKCE-protected.\n    51→ */\n    52→function decodeIdToken(idToken: string): IdTokenClaims {\n    53→  const parts = idToken.split(\".\");\n    54→  if (parts.length !== 3) {\n    55→    throw new Error(\"Invalid id_token format\");\n    56→  }\n    57→  // Restore base64url padding before decoding.\n    58→  const payload = parts[1]!.replace(/-/g, \"+\").replace(/_/g, \"/\");\n    59→  const padded = payload + \"=\".repeat((4 - (payload.length % 4)) % 4);\n    60→  const decoded = atob(padded);\n    61→  return JSON.parse(decoded) as IdTokenClaims;\n    62→}\n    63→\n    64→// ── Component ─────────────────────────────────────────────────────────────────\n    65→\n    66→type CallbackStatus = \"exchanging\" | \"success\" | \"error\";\n    67→\n    68→function AuthCallbackContent() {\n    69→  const searchParams = useSearchParams();\n    70→  const [callbackStatus, setCallbackStatus] = useState<CallbackStatus>(\"exchanging\");\n    71→  const [errorMessage, setErrorMessage] = useState<string>(\"\");\n    72→  // Guard against React StrictMode double-mount: only one exchange should run.\n    73→  const exchangeStartedRef = useRef(false);\n    74→  // Track if component is mounted to prevent state updates after unmount\n    75→  const isMountedRef = useRef(true);\n    76→\n    77→  useEffect(() => {\n    78→    // Set mounted flag on mount and clear on unmount\n    79→    isMountedRef.current = true;\n    80→    return () => {\n    81→      isMountedRef.current = false;\n    82→    };\n    83→  }, []);\n    84→\n    85→  useEffect(() => {\n    86→    // If an exchange is