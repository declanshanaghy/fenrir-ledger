# Fenrir Ledger — Environment Variables Template
# Copy this file to .env.local for local development
# Never commit .env or .env.local — they are gitignored
#
# Sprint 3.2 / hotfix: Google token exchange via server-side proxy.
# The browser handles the full PKCE flow; only the final token exchange
# moves server-side so that GOOGLE_CLIENT_SECRET stays off the client.
# See ADR-005 for the auth architecture decision.

# ─── App version (non-secret, safe for NEXT_PUBLIC_ prefix) ──────────────────
NEXT_PUBLIC_APP_VERSION=1.0.0-sprint3

# ─── Google OAuth 2.0 Client ID ──────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com/
#   1. Create a project (or use an existing one)
#   2. APIs & Services → Credentials → Create OAuth client ID
#   3. Application type: Web application
#   4. Authorised JavaScript origins:
#        http://localhost:9653                (local dev)
#        https://<GKE_INGRESS_HOSTNAME>      (production — GKE Ingress IP or hostname)
#   5. Authorised redirect URIs:
#        http://localhost:9653/auth/callback  (local dev)
#        https://<GKE_INGRESS_HOSTNAME>/auth/callback  (production)
#
# NEXT_PUBLIC_ prefix: safe to expose client-side (used for the auth redirect).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ─── Google OAuth 2.0 Client Secret ──────────────────────────────────────────
# Required for Web Application type clients — Google enforces this even when
# PKCE is used. Desktop/Installed app types omit the secret but restrict
# redirect URIs to localhost only (incompatible with production deployments).
#
# This value is server-only. It is read by /api/auth/token (the token exchange
# proxy) and NEVER sent to the browser.
#
# No NEXT_PUBLIC_ prefix — Next.js will NOT include this in the client bundle.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Google Picker API Key ──────────────────────────────────────────────────
# Required for the "Browse the Archives" import method (Path B).
# Served to authenticated users only via GET /api/config/picker.
#
# Obtain from: https://console.cloud.google.com/
#   1. APIs & Services → Library → Enable "Google Picker API"
#   2. APIs & Services → Library → Enable "Google Sheets API"
#   3. APIs & Services → Credentials → Create Credentials → API Key
#   4. Restrict the key to HTTP referrers:
#        http://localhost:9653/*
#        https://<GKE_INGRESS_HOSTNAME>/*
#   5. Restrict to APIs: Google Picker API
#   6. Update OAuth consent screen scopes: add drive.file, spreadsheets.readonly
#
# No NEXT_PUBLIC_ prefix — server-side only, never included in client bundle.
GOOGLE_PICKER_API_KEY=

# ─── Anthropic API Key ──────────────────────────────────────────────────────
# Required for the Google Sheets import feature (Story 5.2).
# Used server-side only by /api/sheets/import to extract card data from CSV.
#
# Obtain from: https://console.anthropic.com/
# FENRIR_ prefix avoids collision with shell-level ANTHROPIC_API_KEY (e.g. Claude Code).
# No NEXT_PUBLIC_ prefix — Next.js will NOT include this in the client bundle.
FENRIR_ANTHROPIC_API_KEY=

# ─── Entitlement Encryption Key ───────────────────────────────────────────
# AES-256 encryption key for encrypting tokens stored in KV store.
# Must be exactly 64 hex characters (32 bytes).
#
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENTITLEMENT_ENCRYPTION_KEY=your-32-byte-hex-key-64-chars-long-generate-with-crypto

# ─── Application Base URL ────────────────────────────────────────────────
# Deterministic base URL for OAuth redirect URIs (fixes SEV-002).
# Set this in production to avoid relying on x-forwarded-proto / host headers,
# which can be spoofed or incorrect behind certain proxies.
#
# - Production:  https://<GKE_INGRESS_HOSTNAME>  (set via K8s secret)
# - Local dev:   http://localhost:9653  (or leave unset — header fallback works)
#
# When set, OAuth authorize and callback routes use this value instead of
# constructing the URL from request headers. Also used by Stripe checkout/portal
# routes for success/cancel redirect URLs (SEV-002 fix).
# APP_BASE_URL=https://<GKE_INGRESS_HOSTNAME>

# ─── Stripe Integration ────────────────────────────────────────────────────
# Required for subscription/entitlement features (ADR-010).
# All values are server-side only -- never exposed to the client bundle.
#
# Obtain from: https://dashboard.stripe.com/
#   1. Create a product with a recurring price ($3.99/month for Karl tier)
#   2. Copy the price ID (price_xxx) for STRIPE_PRICE_ID
#   3. Developers -> API Keys -> Secret key for STRIPE_SECRET_KEY
#   4. Developers -> Webhooks -> Add endpoint -> copy signing secret
#
# No NEXT_PUBLIC_ prefix (except publishable key) -- never included in client bundle.
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_ID=price_placeholder

# ─── Redis ─────────────────────────────────────────────────────────────────
# In-cluster Redis for entitlement and trial state persistence.
# Production: redis://redis.fenrir-app.svc.cluster.local:6379 (set via K8s secret)
# Local dev:  redis://localhost:6379 (default if unset)
REDIS_URL=redis://localhost:6379

# ─── Agent Orchestration (GKE Autopilot) ──────────────────────────────────
# Required for remote agent sandbox execution via /fire-next-up.
# Agent sandboxes now run as GKE Autopilot Jobs (see infrastructure/k8s/agents/).
#
# CLAUDE_CODE_OAUTH_TOKEN: Long-lived Claude OAuth token for headless execution.
#   Generate with: `claude setup-token` (requires browser, valid for ~1 year).
#   Stored as K8s secret in the agents namespace.
CLAUDE_CODE_OAUTH_TOKEN=
