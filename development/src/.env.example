# Fenrir Ledger — Environment Variables Template
# Copy this file to .env.local for local development
# Never commit .env or .env.local — they are gitignored
#
# Sprint 3.2: PKCE public-client auth (no server secret required).
# Only one variable is needed for authentication.

# ─── App version (non-secret, safe for NEXT_PUBLIC_ prefix) ──────────────────
NEXT_PUBLIC_APP_VERSION=1.0.0-sprint3

# ─── Google OAuth 2.0 Client ID ──────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com/
#   1. Create a project (or use an existing one)
#   2. APIs & Services → Credentials → Create OAuth client ID
#   3. Application type: Web application  (no client_secret needed)
#   4. Authorised JavaScript origins:
#        http://localhost:9653           (local dev)
#        https://fenrir-ledger.vercel.app  (production)
#   5. Authorised redirect URIs:
#        http://localhost:9653/auth/callback   (local dev)
#        https://fenrir-ledger.vercel.app/auth/callback  (production)
#
# No client_secret is required. The PKCE code_verifier replaces it.
# See ADR-005 for the public-client auth architecture decision.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
