# Fenrir Ledger — Environment Variables Template
# Copy this file to .env.local for local development
# Never commit .env or .env.local — they are gitignored
#
# Sprint 3.2 / hotfix: Google token exchange via server-side proxy.
# The browser handles the full PKCE flow; only the final token exchange
# moves server-side so that GOOGLE_CLIENT_SECRET stays off the client.
# See ADR-005 for the auth architecture decision.

# ─── App version (non-secret, safe for NEXT_PUBLIC_ prefix) ──────────────────
NEXT_PUBLIC_APP_VERSION=1.0.0-sprint3

# ─── Google OAuth 2.0 Client ID ──────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com/
#   1. Create a project (or use an existing one)
#   2. APIs & Services → Credentials → Create OAuth client ID
#   3. Application type: Web application
#   4. Authorised JavaScript origins:
#        http://localhost:9653           (local dev)
#        https://fenrir-ledger.vercel.app  (production)
#   5. Authorised redirect URIs:
#        http://localhost:9653/auth/callback   (local dev)
#        https://fenrir-ledger.vercel.app/auth/callback  (production)
#
# NEXT_PUBLIC_ prefix: safe to expose client-side (used for the auth redirect).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ─── Google OAuth 2.0 Client Secret ──────────────────────────────────────────
# Required for Web Application type clients — Google enforces this even when
# PKCE is used. Desktop/Installed app types omit the secret but restrict
# redirect URIs to localhost only (incompatible with Vercel production).
#
# This value is server-only. It is read by /api/auth/token (the token exchange
# proxy) and NEVER sent to the browser.
#
# No NEXT_PUBLIC_ prefix — Next.js will NOT include this in the client bundle.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Anthropic API Key ──────────────────────────────────────────────────────
# Required for the Google Sheets import feature (Story 5.2).
# Used server-side only by /api/sheets/import to extract card data from CSV.
#
# Obtain from: https://console.anthropic.com/
# No NEXT_PUBLIC_ prefix — Next.js will NOT include this in the client bundle.
ANTHROPIC_API_KEY=

# ─── Backend Server URL ──────────────────────────────────────────────────────
# HTTP URL of the Fenrir Ledger backend server (server-side proxy, not exposed
# to browser). Used by /api/sheets/import to proxy long-running import requests
# to the backend. No NEXT_PUBLIC_ prefix — this is server-side only.
BACKEND_URL=http://localhost:9753
