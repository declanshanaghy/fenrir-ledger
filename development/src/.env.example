# Fenrir Ledger — Environment Variables Template
# Copy this file to .env.local for local development
# Never commit .env or .env.local — they are gitignored
#
# Sprint 3.1: Google OIDC auth added (Auth.js v5).
# All variables below are required for the app to start.

# ─── App version (non-secret, safe for NEXT_PUBLIC_ prefix) ──────────────────
NEXT_PUBLIC_APP_VERSION=1.0.0-sprint3

# ─── Google OAuth 2.0 Credentials ────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com/
#   1. Create a project (or use an existing one)
#   2. APIs & Services → Credentials → Create OAuth client ID
#   3. Application type: Web application
#   4. Authorized redirect URIs:
#        http://localhost:9653/api/auth/callback/google   (local dev)
#        https://fenrir-ledger.vercel.app/api/auth/callback/google  (production)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Auth.js v5 Secret ────────────────────────────────────────────────────────
# Used to sign and encrypt the JWT session cookie.
# Generate with: openssl rand -hex 32
AUTH_SECRET=generate-with-openssl-rand-hex-32

# ─── Auth.js URL ──────────────────────────────────────────────────────────────
# The canonical URL of the application. Must match the origin used in
# Google's authorized redirect URIs.
# Local dev: http://localhost:9653
# Vercel production: https://fenrir-ledger.vercel.app
AUTH_URL=http://localhost:9653

# ─── Auth.js Trust Host ───────────────────────────────────────────────────────
# Required for Vercel preview deployments where the hostname is dynamic.
# Set to "true" so Auth.js does not reject the preview URL as untrusted.
# See ADR-004 for the Vercel preview deployment rationale.
AUTH_TRUST_HOST=true
