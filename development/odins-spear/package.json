{
  "name": "odins-spear",
  "description": "TESTS ARE BANNED — DO NOT write tests for this package. Validate via tsc + build ONLY.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 tsx watch --import ./register.mjs src/index.ts",
    "start": "NODE_NO_WARNINGS=1 node --import ./register.mjs dist/index.js",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "verify": "pnpm run verify:tsc && pnpm run verify:build",
    "verify:tsc": "tsc --noEmit",
    "verify:build": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "fenrir-ledger": "workspace:*",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.0.0",
    "stripe": "^20.4.0",
    "tslog": "^4.10.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "google-auth-library": "^10.6.2",
    "tsx": "^4.19.3",
    "typescript": "5.9.3"
  }
}
