{
  "name": "odin-throne-monitor",
  "description": "TESTS ARE BANNED — DO NOT write tests for this package. Validate via tsc + build ONLY.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"pnpm run dev:api\" \"pnpm run dev:ui\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:ui": "vite",
    "build": "pnpm run build:ui && pnpm run build:api",
    "build:ui": "tsc -b tsconfig.ui.json && vite build",
    "build:api": "tsc",
    "start": "node dist/index.js",
    "compile": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm run verify:tsc && pnpm run verify:build",
    "verify:tsc": "tsc --noEmit && tsc --noEmit -p tsconfig.ui.json",
    "verify:build": "pnpm run build:ui && tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@kubernetes/client-node": "^1.0.0",
    "hono": "^4.6.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.0.0",
    "vitest": "^3.1.1"
  },
  "vitest": {
    "include": ["src/__tests__/**/*.test.ts"],
    "environment": "node"
  }
}
