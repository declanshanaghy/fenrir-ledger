{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GqAtMHnSom8hE9knTYMNJs","type":"tool_result","content":"     1→/**\n     2→ * Redis trial store — server-side persistence for trial state.\n     3→ *\n     4→ * Stores and retrieves trial records keyed by browser fingerprint.\n     5→ *\n     6→ * Key format: `trial:{fingerprint}` → StoredTrial\n     7→ *\n     8→ * TTL: 60 days (covers the 30-day trial + 30 days of post-trial data retention).\n     9→ *\n    10→ * @module kv/trial-store\n    11→ */\n    12→\n    13→import { getRedisClient } from \"@/lib/kv/redis-client\";\n    14→import { log } from \"@/lib/logger\";\n    15→import { TRIAL_DURATION_DAYS } from \"@/lib/trial-utils\";\n    16→\n    17→// ---------------------------------------------------------------------------\n    18→// Types\n    19→// ---------------------------------------------------------------------------\n    20→\n    21→/** Shape of a trial record stored in Redis. */\n    22→export interface StoredTrial {\n    23→  /** ISO timestamp of when the trial started (first card creation). */\n    24→  startDate: string;\n    25→  /** ISO timestamp of when the user converted to Karl (if they did). */\n    26→  convertedDate?: string;\n    27→}\n    28→\n    29→// ---------------------------------------------------------------------------\n    30→// Constants\n    31→// ---------------------------------------------------------------------------\n    32→\n    33→/** 60 days in seconds — covers trial + post-trial data retention. */\n    34→const TRIAL_TTL_SECONDS = 60 * 24 * 60 * 60;\n    35→\n    36→// ---------------------------------------------------------------------------\n    37→// Key builders\n    38→// ---------------------------------------------------------------------------\n    39→\n    40→/**\n    41→ * Builds the KV key for a trial record.\n    42→ *\n    43→ * @param fingerprint - 64-char SHA-256 hex fingerprint\n    44→ * @returns KV key string\n    45→ */\n    46→function trialKey(fingerprint: string): string {\n    47→  return `trial:${fingerprint}`;\n    48→}\n    49→\n    50→// ---------------------------------------------------------------------------\n    51→// Operations\n    52→// ---------------------------------------------------------------------------\n    53→\n    54→/**\n    55→ * Retrieves a trial record by fingerprint.\n    56→ *\n    57→ * @param fingerprint - 64-char SHA-256 hex fingerprint\n    58→ * @returns The stored trial record or null if not found / expired\n    59→ */\n    60→export async function getTrial(fingerprint: string): Promise<StoredTrial | null> {\n    61→  log.debug(\"getTrial called\", { fingerprint });\n    62→  try {\n    63→    const redis = getRedisClient();\n    64→    const raw = await redis.get(trialKey(fingerprint));\n    65→    const result: StoredTrial | null = raw ? JSON.parse(raw) : null;\n    66→    log.debug(\"getTrial returning\", {\n    67→      fingerprint,\n    68→      found: result !== null,\n    69→      startDate: result?.startDate,\n    70→    });\n    71→    return result;\n    72→  } catch (err) {\n    73→    const message = err instanceof Error ? err.message : String(err);\n    74→    log.error(\"getTrial failed\", { fingerprint, error: message });\n    75→    return null;\n    76→  }\n    77→}\n    78→\n    79→/**\n    80→ * Creates a new trial record in KV. If a record already exists for this\n    81→ * fingerprint, this is a no-op — the original start date is preserved.\n    82→ *\n    83→ * @param fingerprint - 64-char SHA-256 hex fingerprint\n    84→ * @returns The stored trial record (existing or newly created)\n    85→ */\n    86→export async function initTrial(fingerprint: string): Promise<StoredTrial> {\n    87→  log.debug(\"initTrial called\", { fingerprint });\n    88→\n    89→  // Check for existing trial first (idempotent)\n    90→  const existing = await getTrial(fingerprint);\n    91→  if (existing) {\n    92→    log.debug(\"initTrial returning\", { fingerprint, reason: \"already_exists\", startDate: existing.startDate });\n    93→    return existing;\n    94→  }\n    95→\n    96→  const trial: StoredTrial = {\n    97→    startDate: new Date().toISOString(),\n    98→  };\n    99→\n   100→  try {\n   101→    const redis = getRedisClient();\n   102→    await redis.set(trialKey(fingerprint), JSON.stringify(trial), \"EX\", TRIAL_TTL_SECONDS);\n   103→    log.debug(\"initTrial returning\", { fingerprint, startDate: trial.startDate });\n   104→    return trial;\n   105→  } catch (err) {\n   106→    const message = err instanceof Error ? err.message : String(err);\n   107→    log.error(\"initTrial failed\", { fingerprint, error: message });\n   108→    throw err;\n   109→  }\n   110→}\n   111→\n   112→/**\n   113→ * Marks a trial as converted by setting the convertedDate field.\n   114→ * Called after a successful Stripe subscription from a trial user.\n   115→ *\n   116→ * @param fingerprint - 64-char SHA-256 hex fingerprint\n   117→ * @returns true if the trial was found and updated, false otherwise\n   118→ */\n   119→export async function markTrialConverted(fingerprint: string): Promise<boolean> {\n   120→  log.debug(\"markTrialConverted called\", { fingerprint });\n   121→\n   122→  const existing = await getTrial(fingerprint);\n   123→  if (!existing) {\n   124→    log.debug(\"markTrialConverted: no trial found\", { fingerprint });\n   125→    return false;\n   126→  }\n   127→\n   128→  if (existing.convertedDate) {\n   129→    log.debug(\"markTrialConverted: already converted\", { fingerprint });\n   130→    return true;\n   131→  }\n   132→\n   133→  const updated: StoredTrial = {\n   134→    ...existing,\n   135→    convertedDate: new Date().toISOString(),\n   136→  };\n   137→\n   138→  try {\n   139→    const redis = getRedisClient();\n   140→    await redis.set(trialKey(fingerprint), JSON.stringify(updated), \"EX\", TRIAL_TTL_SECONDS);\n   141→    log.debug(\"markTrialConverted success\", {\n   142→      fingerprint,\n   143→      convertedDate: updated.convertedDate,\n   144→    });\n   145→    return true;\n   146→  } catch (err) {\n   147→    const message = err instanceof Error ? err.message : String(err);\n   148→    log.error(\"markTrialConverted failed\", { fingerprint, error: message });\n   149→    return false;\n   150→  }\n   151→}\n   152→\n   153→/**\n   154→ * Computes the trial status for a given trial record.\n   155→ *\n   156→ * @param trial - The stored trial record (or null if none exists)\n   157→ * @returns Object with remaining days and status\n   158→ */\n   159→export function computeTrialStatus(trial: StoredTrial | null): {\n   160→  remainingDays: number;\n   161→  status: \"active\" | \"expired\" | \"converted\" | \"none\";\n   162→  convertedDate?: string;\n   163→} {\n   164→  if (!trial) {\n   165→    return { remainingDays: 0, status: \"none\" };\n   166→  }\n   167→\n   168→  if (trial.convertedDate) {\n   169→    return { remainingDays: 0, status: \"converted\", convertedDate: trial.convertedDate };\n   170→  }\n   171→\n   172→  const startDate = new Date(trial.startDate);\n   173→  const now = new Date();\n   174→  const elapsedMs = now.getTime() - startDate.getTime();\n   175→  const elapsedDays = Math.floor(elapsedMs / (24 * 60 * 60 * 1000));\n   176→  const remainingDays = Math.max(0, TRIAL_DURATION_DAYS - elapsedDays);\n   177→\n   178→  if (remainingDays <= 0) {\n   179→    return { remainingDays: 0, status: \"expired\" };\n   180→  }\n   181→\n   182→  return { remainingDays, status: \"active\" };\n   183→}\n   184→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8f0c11e7-f1f2-45f1-b28f-b520f037c3ce","uuid":"8a91b452-2512-4a27-80c7-19505d56d281","tool_use_result":{"type":"text","file":{"filePath":"/workspace/repo/development/frontend/src/lib/kv/trial-store.ts","content":"/**\n * Redis trial store — server-side persistence for trial state.\n *\n * Stores and retrieves trial records keyed by browser fingerprint.\n *\n * Key format: `trial:{fingerprint}` → StoredTrial\n *\n * TTL: 60 days (covers the 30-day trial + 30 days of post-trial data retention).\n *\n * @module kv/trial-store\n */\n\nimport { getRedisClient } from \"@/lib/kv/redis-client\";\nimport { log } from \"@/lib/logger\";\nimport { TRIAL_DURATION_DAYS } from \"@/lib/trial-utils\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\n/** Shape of a trial record stored in Redis. */\nexport interface StoredTrial {\n  /** ISO timestamp of when the trial started (first card creation). */\n  startDate: string;\n  /** ISO timestamp of when the user converted to Karl (if they did). */\n  convertedDate?: string;\n}\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\n/** 60 days in seconds — covers trial + post-trial data retention. */\nconst TRIAL_TTL_SECONDS = 60 * 24 * 60 * 60;\n\n// ---------------------------------------------------------------------------\n// Key builders\n// ---------------------------------------------------------------------------\n\n/**\n * Builds the KV key for a trial record.\n *\n * @param fingerprint - 64-char SHA-256 hex fingerprint\n * @returns KV key string\n */\nfunction trialKey(fingerprint: string): string {\n  return `trial:${fingerprint}`;\n}\n\n// ---------------------------------------------------------------------------\n// Operations\n// ---------------------------------------------------------------------------\n\n/**\n * Retrieves a trial record by fingerprint.\n *\n * @param fingerprint - 64-char SHA-256 hex fingerprint\n * @returns The stored trial record or null if not found / expired\n */\nexport async function getTrial(fingerprint: string): Promise<StoredTrial | null> {\n  log.debug(\"getTrial called\", { fingerprint });\n  try {\n    const redis = getRedisClient();\n    const raw = await redis.get(trialKey(fingerprint));\n    const result: StoredTrial | null = raw ? JSON.parse(raw) : null;\n    log.debug(\"getTrial returning\", {\n      fingerprint,\n      found: result !== null,\n      startDate: result?.startDate,\n    });\n    return result;\n  } catch (err) {\n    const message = err instanceof Error ? err.message : String(err);\n    log.error(\"getTrial failed\", { fingerprint, error: message });\n    return null;\n  }\n}\n\n/**\n * Creates a new trial record in KV. If a record already exists for this\n * fingerprint, this is a no-op — the original start date is preserved.\n *\n * @param fingerprint - 64-char SHA-256 hex fingerprint\n * @returns The stored trial record (existing or newly created)\n */\nexport async function initTrial(fingerprint: string): Promise<StoredTrial> {\n  log.debug(\"initTrial called\", { fingerprint });\n\n  // Check for existing trial first (idempotent)\n  const existing = await getTrial(fingerprint);\n  if (existing) {\n    log.debug(\"initTrial returning\", { fingerprint, reason: \"already_exists\", startDate: existing.startDate });\n    return existing;\n  }\n\n  const trial: StoredTrial = {\n    startDate: new Date().toISOString(),\n  };\n\n  try {\n    const redis = getRedisClient();\n    await redis.set(trialKey(fingerprint), JSON.stringify(trial), \"EX\", TRIAL_TTL_SECONDS);\n    log.debug(\"initTrial returning\", { fingerprint, startDate: trial.startDate });\n    return trial;\n  } catch (err) {\n    const message = err instanceof Error ? err.message : String(err);\n    log.error(\"initTrial failed\", { fingerprint, error: message });\n    throw err;\n  }\n}\n\n/**\n * Marks a trial as converted by setting the convertedDate field.\n * Called after a successful Stripe subscription from a trial user.\n *\n * @param fingerprint - 64-char SHA-256 hex fingerprint\n * @returns true if the trial was found and updated, false otherwise\n */\nexport async function markTrialConverted(fingerprint: string): Promise<boolean> {\n  log.debug(\"markTrialConverted called\", { fingerprint });\n\n  const existing = await getTrial(fingerprint);\n  if (!existing) {\n    log.debug(\"markTrialConverted: no trial found\", { fingerprint });\n    return false;\n  }\n\n  if (existing.convertedDate) {\n    log.debug(\"markTrialConverted: already converted\", { fingerprint });\n    return true;\n  }\n\n  const updated: StoredTrial = {\n    ...existing,\n    convertedDate: new Date().toISOString(),\n  };\n\n  try {\n    const redis = getRedisClient();\n    await redis.set(trialKey(fingerprint), JSON.stringify(updated), \"EX\", TRIAL_TTL_SECONDS);\n    log.debug(\"markTrialConverted success\", {\n      fingerprint,\n      convertedDate: updated.convertedDate,\n    });\n    return true;\n  } catch (err) {\n    const message = err instanceof Error ? err.message : String(err);\n    log.error(\"markTrialConverted failed\", { fingerprint, error: message });\n    return false;\n  }\n}\n\n/**\n * Computes the trial status for a given trial record.\n *\n * @param trial - The stored trial record (or null if none exists)\n * @returns Object with remaining days and status\n */\nexport function computeTrialStatus(trial: StoredTrial | null): {\n  remainingDays: number;\n  status: \"active\" | \"expired\" | \"converted\" | \"none\";\n  convertedDate?: string;\n} {\n  if (!trial) {\n    return { remainingDays: 0, status: \"none\" };\n  }\n\n  if (trial.convertedDate) {\n    return { remainingDays: 0, status: \"converted\", convertedDate: trial.convertedDate };\n  }\n\n  const startDate = new Date(trial.startDate);\n  const now = new Date();\n  const elapsedMs = now.getTime() - startDate.getTime();\n  const elapsedDays = Math.floor(elapsedMs / (24 * 60 * 60 * 1000));\n  const remainingDays = Math.max(0, TRIAL_DURATION_DAYS - elapsedDays);\n\n  if (remainingDays <= 0) {\n    return { remainingDays: 0, status: \"expired\" };\n  }\n\n  return { remainingDays, status: \"active\" };\n}\n","numLines":184,"startLine":1,"totalLines":184}}}
