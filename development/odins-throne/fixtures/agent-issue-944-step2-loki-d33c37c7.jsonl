{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014uWEQePW9yu6wHBSMEzWhz","type":"tool_result","content":"commit 035e95daa1c79fa2d5af366efd12714555a2f2f5\nAuthor: FiremanDecko (GKE Agent) <firemandecko@fenrir-ledger.dev>\nDate:   Sun Mar 15 04:03:04 2026 +0000\n\n    fix: resolve trial not starting on Google sign-in — issue:944\n    \n    Root cause: the fire-and-forget trial init fetch in the auth callback page\n    used the default keepalive:false, so browsers aborted the in-flight request\n    when window.location.replace() navigated away. This regressed #922 in\n    production where in-cluster Redis is slower than Vercel KV was, making the\n    race condition consistently trigger.\n    \n    Two-layer fix:\n    1. Add keepalive:true to the /api/trial/init fetch in callback/page.tsx so\n       the browser completes the request even after page navigation.\n    2. Add defense-in-depth auto-initialization in /api/trial/status/route.ts:\n       if no trial exists when status is checked, initTrial() is called before\n       computing the status. This fallback handles any future init failures and\n       ensures canceled Stripe customers can still start a trial (no Stripe\n       status check is performed in the trial flow).\n    \n    Tests: 14 new Vitest integration tests for POST /api/trial/status covering\n    auto-init, canceled-Stripe-customer AC, active/expired/converted states,\n    auth/validation/rate-limit edge cases (785 total passing).\n    \n    Fixes #944\n    \n    Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>\n\ndiff --git a/development/frontend/src/app/api/trial/status/route.ts b/development/frontend/src/app/api/trial/status/route.ts\nindex bab9cd6..df21745 100644\n--- a/development/frontend/src/app/api/trial/status/route.ts\n+++ b/development/frontend/src/app/api/trial/status/route.ts\n@@ -18,7 +18,7 @@ import { requireAuth } from \"@/lib/auth/require-auth\";\n import { rateLimit } from \"@/lib/rate-limit\";\n import { log } from \"@/lib/logger\";\n import { isValidFingerprint } from \"@/lib/trial-utils\";\n-import { getTrial, computeTrialStatus } from \"@/lib/kv/trial-store\";\n+import { getTrial, initTrial, computeTrialStatus } from \"@/lib/kv/trial-store\";\n \n export async function POST(request: NextRequest): Promise<NextResponse> {\n   log.debug(\"POST /api/trial/status called\");\n@@ -79,9 +79,22 @@ export async function POST(request: NextRequest): Promise<NextResponse> {\n     );\n   }\n \n-  // Retrieve trial and compute status\n+  // Retrieve trial and compute status.\n+  // If no trial exists yet (e.g. the auth-callback keepalive fetch was dropped),\n+  // auto-initialize it here as a defense-in-depth fallback (#944).\n+  // initTrial is idempotent — it is a no-op if a trial already exists.\n   try {\n-    const trial = await getTrial(fingerprint);\n+    let trial = await getTrial(fingerprint);\n+    if (!trial) {\n+      log.debug(\"POST /api/trial/status: no trial found, auto-initializing\", { fingerprint });\n+      try {\n+        trial = await initTrial(fingerprint);\n+      } catch (initErr) {\n+        const msg = initErr instanceof Error ? initErr.message : String(initErr);\n+        log.error(\"POST /api/trial/status: auto-init failed\", { fingerprint, error: msg });\n+        // Fall through with trial === null — computeTrialStatus returns \"none\"\n+      }\n+    }\n     const result = computeTrialStatus(trial);\n \n     log.debug(\"POST /api/trial/status returning\", {","is_error":false}]},"parent_tool_use_id":null,"session_id":"8f0c11e7-f1f2-45f1-b28f-b520f037c3ce","uuid":"66b9547a-0af2-44fe-8b9e-493279b5f0ea","tool_use_result":{"stdout":"commit 035e95daa1c79fa2d5af366efd12714555a2f2f5\nAuthor: FiremanDecko (GKE Agent) <firemandecko@fenrir-ledger.dev>\nDate:   Sun Mar 15 04:03:04 2026 +0000\n\n    fix: resolve trial not starting on Google sign-in — issue:944\n    \n    Root cause: the fire-and-forget trial init fetch in the auth callback page\n    used the default keepalive:false, so browsers aborted the in-flight request\n    when window.location.replace() navigated away. This regressed #922 in\n    production where in-cluster Redis is slower than Vercel KV was, making the\n    race condition consistently trigger.\n    \n    Two-layer fix:\n    1. Add keepalive:true to the /api/trial/init fetch in callback/page.tsx so\n       the browser completes the request even after page navigation.\n    2. Add defense-in-depth auto-initialization in /api/trial/status/route.ts:\n       if no trial exists when status is checked, initTrial() is called before\n       computing the status. This fallback handles any future init failures and\n       ensures canceled Stripe customers can still start a trial (no Stripe\n       status check is performed in the trial flow).\n    \n    Tests: 14 new Vitest integration tests for POST /api/trial/status covering\n    auto-init, canceled-Stripe-customer AC, active/expired/converted states,\n    auth/validation/rate-limit edge cases (785 total passing).\n    \n    Fixes #944\n    \n    Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>\n\ndiff --git a/development/frontend/src/app/api/trial/status/route.ts b/development/frontend/src/app/api/trial/status/route.ts\nindex bab9cd6..df21745 100644\n--- a/development/frontend/src/app/api/trial/status/route.ts\n+++ b/development/frontend/src/app/api/trial/status/route.ts\n@@ -18,7 +18,7 @@ import { requireAuth } from \"@/lib/auth/require-auth\";\n import { rateLimit } from \"@/lib/rate-limit\";\n import { log } from \"@/lib/logger\";\n import { isValidFingerprint } from \"@/lib/trial-utils\";\n-import { getTrial, computeTrialStatus } from \"@/lib/kv/trial-store\";\n+import { getTrial, initTrial, computeTrialStatus } from \"@/lib/kv/trial-store\";\n \n export async function POST(request: NextRequest): Promise<NextResponse> {\n   log.debug(\"POST /api/trial/status called\");\n@@ -79,9 +79,22 @@ export async function POST(request: NextRequest): Promise<NextResponse> {\n     );\n   }\n \n-  // Retrieve trial and compute status\n+  // Retrieve trial and compute status.\n+  // If no trial exists yet (e.g. the auth-callback keepalive fetch was dropped),\n+  // auto-initialize it here as a defense-in-depth fallback (#944).\n+  // initTrial is idempotent — it is a no-op if a trial already exists.\n   try {\n-    const trial = await getTrial(fingerprint);\n+    let trial = await getTrial(fingerprint);\n+    if (!trial) {\n+      log.debug(\"POST /api/trial/status: no trial found, auto-initializing\", { fingerprint });\n+      try {\n+        trial = await initTrial(fingerprint);\n+      } catch (initErr) {\n+        const msg = initErr instanceof Error ? initErr.message : String(initErr);\n+        log.error(\"POST /api/trial/status: auto-init failed\", { fingerprint, error: msg });\n+        // Fall through with trial === null — computeTrialStatus returns \"none\"\n+      }\n+    }\n     const result = computeTrialStatus(trial);\n \n     log.debug(\"POST /api/trial/status returning\", {","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RJgFXR8raLCuHV5j9pvByo","type":"tool_result","content":"commit 035e95daa1c79fa2d5af366efd12714555a2f2f5\nAuthor: FiremanDecko (GKE Agent) <firemandecko@fenrir-ledger.dev>\nDate:   Sun Mar 15 04:03:04 2026 +0000\n\n    fix: resolve trial not starting on Google sign-in — issue:944\n    \n    Root cause: the fire-and-forget trial init fetch in the auth callback page\n    used the default keepalive:false, so browsers aborted the in-flight request\n    when window.location.replace() navigated away. This regressed #922 in\n    production where in-cluster Redis is slower than Vercel KV was, making the\n    race condition consistently trigger.\n    \n    Two-layer fix:\n    1. Add keepalive:true to the /api/trial/init fetch in callback/page.tsx so\n       the browser completes the request even after page navigation.\n    2. Add defense-in-depth auto-initialization in /api/trial/status/route.ts:\n       if no trial exists when status is checked, initTrial() is called before\n       computing the status. This fallback handles any future init failures and\n       ensures canceled Stripe customers can still start a trial (no Stripe\n       status check is performed in the trial flow).\n    \n    Tests: 14 new Vitest integration tests for POST /api/trial/status covering\n    auto-init, canceled-Stripe-customer AC, active/expired/converted states,\n    auth/validation/rate-limit edge cases (785 total passing).\n    \n    Fixes #944\n    \n    Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>\n\ndiff --git a/development/frontend/src/app/ledger/auth/callback/page.tsx b/development/frontend/src/app/ledger/auth/callback/page.tsx\nindex 2c6a470..9abee89 100644\n--- a/development/frontend/src/app/ledger/auth/callback/page.tsx\n+++ b/development/frontend/src/app/ledger/auth/callback/page.tsx\n@@ -194,9 +194,11 @@ function AuthCallbackContent() {\n \n         setSession(session);\n \n-        // Fire-and-forget trial init on first sign-in (#922).\n+        // Fire-and-forget trial init on first sign-in (#922 / #944).\n         // Idempotent — if a trial already exists for this fingerprint it is preserved.\n-        // Do not await: trial init must not block the auth redirect.\n+        // keepalive:true ensures the request completes even after window.location.replace()\n+        // navigates away — without it the browser aborts in-flight requests on navigation\n+        // (regression root cause for #944).\n         void (async () => {\n           try {\n             const fingerprint = await computeFingerprint();\n@@ -208,12 +210,13 @@ function AuthCallbackContent() {\n                   Authorization: `Bearer ${tokens.id_token}`,\n                 },\n                 body: JSON.stringify({ fingerprint }),\n+                keepalive: true,\n               });\n               // Clear cached trial status so the next useTrialStatus fetch is fresh.\n               clearTrialStatusCache();\n             }\n           } catch {\n-            // Non-fatal — trial will be auto-initialized on first Karl feature access.\n+            // Non-fatal — trial will be auto-initialized on first /api/trial/status call.\n           }\n         })();","is_error":false}]},"parent_tool_use_id":null,"session_id":"8f0c11e7-f1f2-45f1-b28f-b520f037c3ce","uuid":"7c1e316a-ff24-40bb-b93f-4257a302b824","tool_use_result":{"stdout":"commit 035e95daa1c79fa2d5af366efd12714555a2f2f5\nAuthor: FiremanDecko (GKE Agent) <firemandecko@fenrir-ledger.dev>\nDate:   Sun Mar 15 04:03:04 2026 +0000\n\n    fix: resolve trial not starting on Google sign-in — issue:944\n    \n    Root cause: the fire-and-forget trial init fetch in the auth callback page\n    used the default keepalive:false, so browsers aborted the in-flight request\n    when window.location.replace() navigated away. This regressed #922 in\n    production where in-cluster Redis is slower than Vercel KV was, making the\n    race condition consistently trigger.\n    \n    Two-layer fix:\n    1. Add keepalive:true to the /api/trial/init fetch in callback/page.tsx so\n       the browser completes the request even after page navigation.\n    2. Add defense-in-depth auto-initialization in /api/trial/status/route.ts:\n       if no trial exists when status is checked, initTrial() is called before\n       computing the status. This fallback handles any future init failures and\n       ensures canceled Stripe customers can still start a trial (no Stripe\n       status check is performed in the trial flow).\n    \n    Tests: 14 new Vitest integration tests for POST /api/trial/status covering\n    auto-init, canceled-Stripe-customer AC, active/expired/converted states,\n    auth/validation/rate-limit edge cases (785 total passing).\n    \n    Fixes #944\n    \n    Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>\n\ndiff --git a/development/frontend/src/app/ledger/auth/callback/page.tsx b/development/frontend/src/app/ledger/auth/callback/page.tsx\nindex 2c6a470..9abee89 100644\n--- a/development/frontend/src/app/ledger/auth/callback/page.tsx\n+++ b/development/frontend/src/app/ledger/auth/callback/page.tsx\n@@ -194,9 +194,11 @@ function AuthCallbackContent() {\n \n         setSession(session);\n \n-        // Fire-and-forget trial init on first sign-in (#922).\n+        // Fire-and-forget trial init on first sign-in (#922 / #944).\n         // Idempotent — if a trial already exists for this fingerprint it is preserved.\n-        // Do not await: trial init must not block the auth redirect.\n+        // keepalive:true ensures the request completes even after window.location.replace()\n+        // navigates away — without it the browser aborts in-flight requests on navigation\n+        // (regression root cause for #944).\n         void (async () => {\n           try {\n             const fingerprint = await computeFingerprint();\n@@ -208,12 +210,13 @@ function AuthCallbackContent() {\n                   Authorization: `Bearer ${tokens.id_token}`,\n                 },\n                 body: JSON.stringify({ fingerprint }),\n+                keepalive: true,\n               });\n               // Clear cached trial status so the next useTrialStatus fetch is fresh.\n               clearTrialStatusCache();\n             }\n           } catch {\n-            // Non-fatal — trial will be auto-initialized on first Karl feature access.\n+            // Non-fatal — trial will be auto-initialized on first /api/trial/status call.\n           }\n         })();","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
