{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AsT2RtV49cERowX7AdpnPR","type":"tool_result","content":"     1→/**\n     2→ * Integration tests for POST /api/trial/init\n     3→ *\n     4→ * Covers:\n     5→ *  - Trial auto-starts on first sign-in (new fingerprint → Redis write)\n     6→ *  - Idempotent: second call preserves original start date, no re-write\n     7→ *  - Invalid fingerprint returns 400\n     8→ *  - Missing fingerprint returns 400\n     9→ *  - Unauthenticated request returns 401\n    10→ *  - Redis failure returns 500\n    11→ *\n    12→ * @see src/app/api/trial/init/route.ts\n    13→ * @ref Issue #922\n    14→ */\n    15→\n    16→import { describe, it, expect, beforeEach, vi } from \"vitest\";\n    17→import { NextRequest } from \"next/server\";\n    18→\n    19→// ── Mocks ─────────────────────────────────────────────────────────────────────\n    20→\n    21→const mockRedis = vi.hoisted(() => ({\n    22→  get: vi.fn(),\n    23→  set: vi.fn(),\n    24→}));\n    25→\n    26→vi.mock(\"@/lib/kv/redis-client\", () => ({\n    27→  getRedisClient: () => mockRedis,\n    28→}));\n    29→\n    30→const mockRateLimit = vi.hoisted(() => vi.fn(() => ({ success: true, remaining: 9 })));\n    31→\n    32→vi.mock(\"@/lib/rate-limit\", () => ({\n    33→  rateLimit: mockRateLimit,\n    34→}));\n    35→\n    36→vi.mock(\"@/lib/logger\", () => ({\n    37→  log: { debug: vi.fn(), info: vi.fn(), warn: vi.fn(), error: vi.fn() },\n    38→}));\n    39→\n    40→// requireAuth: by default resolves to an authenticated user. Override per-test for 401 cases.\n    41→const mockRequireAuth = vi.fn();\n    42→vi.mock(\"@/lib/auth/require-auth\", () => ({\n    43→  requireAuth: (...args: unknown[]) => mockRequireAuth(...args),\n    44→}));\n    45→\n    46→// ── Import route handler after mocks ──────────────────────────────────────────\n    47→\n    48→import { POST } from \"@/app/api/trial/init/route\";\n    49→\n    50→// ── Helpers ───────────────────────────────────────────────────────────────────\n    51→\n    52→const VALID_FINGERPRINT = \"a\".repeat(64);\n    53→\n    54→function makeRequest(body: Record<string, unknown> = {}, token = \"valid-token\"): NextRequest {\n    55→  return new NextRequest(\"http://localhost:9653/api/trial/init\", {\n    56→    method: \"POST\",\n    57→    headers: {\n    58→      \"Content-Type\": \"application/json\",\n    59→      Authorization: `Bearer ${token}`,\n    60→      \"x-forwarded-for\": \"127.0.0.1\",\n    61→    },\n    62→    body: JSON.stringify(body),\n    63→  });\n    64→}\n    65→\n    66→function authOk() {\n    67→  mockRequireAuth.mockResolvedValue({ ok: true, user: { sub: \"google-sub-123\" } });\n    68→}\n    69→\n    70→function authFail() {\n    71→  mockRequireAuth.mockResolvedValue({\n    72→    ok: false,\n    73→    response: new Response(JSON.stringify({ error: \"unauthorized\" }), { status: 401 }),\n    74→  });\n    75→}\n    76→\n    77→// ── Tests ──────────────────────────────────────────────────────────────────────\n    78→\n    79→describe(\"POST /api/trial/init\", () => {\n    80→  beforeEach(() => {\n    81→    vi.clearAllMocks();\n    82→    authOk();\n    83→  });\n    84→\n    85→  // ═══════════════════════════════════════════════════════════════════════\n    86→  // Trial auto-starts on first sign-in\n    87→  // ═══════════════════════════════════════════════════════════════════════\n    88→\n    89→  it(\"creates a new trial on first sign-in and returns isNew:true\", async () => {\n    90→    mockRedis.get.mockResolvedValueOnce(null); // no existing trial\n    91→    mockRedis.set.mockResolvedValueOnce(\"OK\");\n    92→\n    93→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    94→    const body = await res.json();\n    95→\n    96→    expect(res.status).toBe(200);\n    97→    expect(body.isNew).toBe(true);\n    98→    expect(typeof body.startDate).toBe(\"string\");\n    99→    expect(mockRedis.set).toHaveBeenCalledOnce();\n   100→    expect(mockRedis.set).toHaveBeenCalledWith(\n   101→      `trial:${VALID_FINGERPRINT}`,\n   102→      expect.any(String),\n   103→      \"EX\",\n   104→      expect.any(Number),\n   105→    );\n   106→  });\n   107→\n   108→  it(\"writes a valid ISO start date to Redis on first sign-in\", async () => {\n   109→    mockRedis.get.mockResolvedValueOnce(null);\n   110→    mockRedis.set.mockResolvedValueOnce(\"OK\");\n   111→\n   112→    const before = Date.now();\n   113→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   114→    const after = Date.now();\n   115→    const body = await res.json();\n   116→\n   117→    const startDate = new Date(body.startDate as string).getTime();\n   118→    expect(startDate).toBeGreaterThanOrEqual(before);\n   119→    expect(startDate).toBeLessThanOrEqual(after);\n   120→  });\n   121→\n   122→  // ═══════════════════════════════════════════════════════════════════════\n   123→  // Idempotent — second sign-in preserves original trial\n   124→  // ═══════════════════════════════════════════════════════════════════════\n   125→\n   126→  it(\"returns isNew:false and preserves original startDate on second call\", async () => {\n   127→    const originalStartDate = \"2026-03-01T00:00:00.000Z\";\n   128→    mockRedis.get.mockResolvedValueOnce(\n   129→      JSON.stringify({ startDate: originalStartDate }),\n   130→    );\n   131→\n   132→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   133→    const body = await res.json();\n   134→\n   135→    expect(res.status).toBe(200);\n   136→    expect(body.isNew).toBe(false);\n   137→    expect(body.startDate).toBe(originalStartDate);\n   138→    // Redis set should NOT be called — existing trial preserved\n   139→    expect(mockRedis.set).not.toHaveBeenCalled();\n   140→  });\n   141→\n   142→  // ═══════════════════════════════════════════════════════════════════════\n   143→  // Unauthenticated request blocked\n   144→  // ═══════════════════════════════════════════════════════════════════════\n   145→\n   146→  it(\"returns 401 for unauthenticated request\", async () => {\n   147→    authFail();\n   148→\n   149→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }, \"\"));\n   150→    expect(res.status).toBe(401);\n   151→  });\n   152→\n   153→  // ═══════════════════════════════════════════════════════════════════════\n   154→  // Input validation\n   155→  // ═══════════════════════════════════════════════════════════════════════\n   156→\n   157→  it(\"returns 400 for invalid fingerprint (too short)\", async () => {\n   158→    const res = await POST(makeRequest({ fingerprint: \"abc123\" }));\n   159→    const body = await res.json();\n   160→\n   161→    expect(res.status).toBe(400);\n   162→    expect(body.error).toBe(\"invalid_fingerprint\");\n   163→  });\n   164→\n   165→  it(\"returns 400 for invalid fingerprint (uppercase hex)\", async () => {\n   166→    const res = await POST(makeRequest({ fingerprint: \"A\".repeat(64) }));\n   167→    const body = await res.json();\n   168→\n   169→    expect(res.status).toBe(400);\n   170→    expect(body.error).toBe(\"invalid_fingerprint\");\n   171→  });\n   172→\n   173→  it(\"returns 400 for missing fingerprint field\", async () => {\n   174→    const res = await POST(makeRequest({ notAFingerprint: \"whatever\" }));\n   175→    const body = await res.json();\n   176→\n   177→    expect(res.status).toBe(400);\n   178→    expect(body.error).toBe(\"invalid_body\");\n   179→  });\n   180→\n   181→  it(\"returns 400 for empty body\", async () => {\n   182→    const req = new NextRequest(\"http://localhost:9653/api/trial/init\", {\n   183→      method: \"POST\",\n   184→      headers: {\n   185→        \"Content-Type\": \"application/json\",\n   186→        Authorization: \"Bearer valid-token\",\n   187→        \"x-forwarded-for\": \"127.0.0.1\",\n   188→      },\n   189→      body: \"not-valid-json\",\n   190→    });\n   191→\n   192→    const res = await POST(req);\n   193→    expect(res.status).toBe(400);\n   194→  });\n   195→\n   196→  // ═══════════════════════════════════════════════════════════════════════\n   197→  // Redis failure\n   198→  // ═══════════════════════════════════════════════════════════════════════\n   199→\n   200→  it(\"returns 500 when Redis write fails\", async () => {\n   201→    mockRedis.get.mockResolvedValueOnce(null); // no existing trial\n   202→    mockRedis.set.mockRejectedValueOnce(new Error(\"Redis unavailable\"));\n   203→\n   204→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   205→    const body = await res.json();\n   206→\n   207→    expect(res.status).toBe(500);\n   208→    expect(body.error).toBe(\"internal_error\");\n   209→  });\n   210→\n   211→  // ═══════════════════════════════════════════════════════════════════════\n   212→  // Cache-Control header\n   213→  // ═══════════════════════════════════════════════════════════════════════\n   214→\n   215→  it(\"response includes Cache-Control: no-store\", async () => {\n   216→    mockRedis.get.mockResolvedValueOnce(null);\n   217→    mockRedis.set.mockResolvedValueOnce(\"OK\");\n   218→\n   219→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   220→\n   221→    expect(res.headers.get(\"Cache-Control\")).toBe(\"no-store\");\n   222→  });\n   223→\n   224→  // ═══════════════════════════════════════════════════════════════════════\n   225→  // Rate limiting — Loki QA addition (#922)\n   226→  // ═══════════════════════════════════════════════════════════════════════\n   227→\n   228→  it(\"returns 429 when rate limit is exceeded\", async () => {\n   229→    mockRateLimit.mockReturnValueOnce({ success: false, remaining: 0 });\n   230→\n   231→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   232→    const body = await res.json();\n   233→\n   234→    expect(res.status).toBe(429);\n   235→    expect(body.error).toBe(\"rate_limited\");\n   236→  });\n   237→});\n   238→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8f0c11e7-f1f2-45f1-b28f-b520f037c3ce","uuid":"3e012aaa-f3b2-42c7-a544-3b3bf53a404b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/repo/development/frontend/src/__tests__/trial/trial-init-route.test.ts","content":"/**\n * Integration tests for POST /api/trial/init\n *\n * Covers:\n *  - Trial auto-starts on first sign-in (new fingerprint → Redis write)\n *  - Idempotent: second call preserves original start date, no re-write\n *  - Invalid fingerprint returns 400\n *  - Missing fingerprint returns 400\n *  - Unauthenticated request returns 401\n *  - Redis failure returns 500\n *\n * @see src/app/api/trial/init/route.ts\n * @ref Issue #922\n */\n\nimport { describe, it, expect, beforeEach, vi } from \"vitest\";\nimport { NextRequest } from \"next/server\";\n\n// ── Mocks ─────────────────────────────────────────────────────────────────────\n\nconst mockRedis = vi.hoisted(() => ({\n  get: vi.fn(),\n  set: vi.fn(),\n}));\n\nvi.mock(\"@/lib/kv/redis-client\", () => ({\n  getRedisClient: () => mockRedis,\n}));\n\nconst mockRateLimit = vi.hoisted(() => vi.fn(() => ({ success: true, remaining: 9 })));\n\nvi.mock(\"@/lib/rate-limit\", () => ({\n  rateLimit: mockRateLimit,\n}));\n\nvi.mock(\"@/lib/logger\", () => ({\n  log: { debug: vi.fn(), info: vi.fn(), warn: vi.fn(), error: vi.fn() },\n}));\n\n// requireAuth: by default resolves to an authenticated user. Override per-test for 401 cases.\nconst mockRequireAuth = vi.fn();\nvi.mock(\"@/lib/auth/require-auth\", () => ({\n  requireAuth: (...args: unknown[]) => mockRequireAuth(...args),\n}));\n\n// ── Import route handler after mocks ──────────────────────────────────────────\n\nimport { POST } from \"@/app/api/trial/init/route\";\n\n// ── Helpers ───────────────────────────────────────────────────────────────────\n\nconst VALID_FINGERPRINT = \"a\".repeat(64);\n\nfunction makeRequest(body: Record<string, unknown> = {}, token = \"valid-token\"): NextRequest {\n  return new NextRequest(\"http://localhost:9653/api/trial/init\", {\n    method: \"POST\",\n    headers: {\n      \"Content-Type\": \"application/json\",\n      Authorization: `Bearer ${token}`,\n      \"x-forwarded-for\": \"127.0.0.1\",\n    },\n    body: JSON.stringify(body),\n  });\n}\n\nfunction authOk() {\n  mockRequireAuth.mockResolvedValue({ ok: true, user: { sub: \"google-sub-123\" } });\n}\n\nfunction authFail() {\n  mockRequireAuth.mockResolvedValue({\n    ok: false,\n    response: new Response(JSON.stringify({ error: \"unauthorized\" }), { status: 401 }),\n  });\n}\n\n// ── Tests ──────────────────────────────────────────────────────────────────────\n\ndescribe(\"POST /api/trial/init\", () => {\n  beforeEach(() => {\n    vi.clearAllMocks();\n    authOk();\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Trial auto-starts on first sign-in\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"creates a new trial on first sign-in and returns isNew:true\", async () => {\n    mockRedis.get.mockResolvedValueOnce(null); // no existing trial\n    mockRedis.set.mockResolvedValueOnce(\"OK\");\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(200);\n    expect(body.isNew).toBe(true);\n    expect(typeof body.startDate).toBe(\"string\");\n    expect(mockRedis.set).toHaveBeenCalledOnce();\n    expect(mockRedis.set).toHaveBeenCalledWith(\n      `trial:${VALID_FINGERPRINT}`,\n      expect.any(String),\n      \"EX\",\n      expect.any(Number),\n    );\n  });\n\n  it(\"writes a valid ISO start date to Redis on first sign-in\", async () => {\n    mockRedis.get.mockResolvedValueOnce(null);\n    mockRedis.set.mockResolvedValueOnce(\"OK\");\n\n    const before = Date.now();\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const after = Date.now();\n    const body = await res.json();\n\n    const startDate = new Date(body.startDate as string).getTime();\n    expect(startDate).toBeGreaterThanOrEqual(before);\n    expect(startDate).toBeLessThanOrEqual(after);\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Idempotent — second sign-in preserves original trial\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns isNew:false and preserves original startDate on second call\", async () => {\n    const originalStartDate = \"2026-03-01T00:00:00.000Z\";\n    mockRedis.get.mockResolvedValueOnce(\n      JSON.stringify({ startDate: originalStartDate }),\n    );\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(200);\n    expect(body.isNew).toBe(false);\n    expect(body.startDate).toBe(originalStartDate);\n    // Redis set should NOT be called — existing trial preserved\n    expect(mockRedis.set).not.toHaveBeenCalled();\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Unauthenticated request blocked\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns 401 for unauthenticated request\", async () => {\n    authFail();\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }, \"\"));\n    expect(res.status).toBe(401);\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Input validation\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns 400 for invalid fingerprint (too short)\", async () => {\n    const res = await POST(makeRequest({ fingerprint: \"abc123\" }));\n    const body = await res.json();\n\n    expect(res.status).toBe(400);\n    expect(body.error).toBe(\"invalid_fingerprint\");\n  });\n\n  it(\"returns 400 for invalid fingerprint (uppercase hex)\", async () => {\n    const res = await POST(makeRequest({ fingerprint: \"A\".repeat(64) }));\n    const body = await res.json();\n\n    expect(res.status).toBe(400);\n    expect(body.error).toBe(\"invalid_fingerprint\");\n  });\n\n  it(\"returns 400 for missing fingerprint field\", async () => {\n    const res = await POST(makeRequest({ notAFingerprint: \"whatever\" }));\n    const body = await res.json();\n\n    expect(res.status).toBe(400);\n    expect(body.error).toBe(\"invalid_body\");\n  });\n\n  it(\"returns 400 for empty body\", async () => {\n    const req = new NextRequest(\"http://localhost:9653/api/trial/init\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: \"Bearer valid-token\",\n        \"x-forwarded-for\": \"127.0.0.1\",\n      },\n      body: \"not-valid-json\",\n    });\n\n    const res = await POST(req);\n    expect(res.status).toBe(400);\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Redis failure\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns 500 when Redis write fails\", async () => {\n    mockRedis.get.mockResolvedValueOnce(null); // no existing trial\n    mockRedis.set.mockRejectedValueOnce(new Error(\"Redis unavailable\"));\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(500);\n    expect(body.error).toBe(\"internal_error\");\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Cache-Control header\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"response includes Cache-Control: no-store\", async () => {\n    mockRedis.get.mockResolvedValueOnce(null);\n    mockRedis.set.mockResolvedValueOnce(\"OK\");\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n\n    expect(res.headers.get(\"Cache-Control\")).toBe(\"no-store\");\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Rate limiting — Loki QA addition (#922)\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns 429 when rate limit is exceeded\", async () => {\n    mockRateLimit.mockReturnValueOnce({ success: false, remaining: 0 });\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(429);\n    expect(body.error).toBe(\"rate_limited\");\n  });\n});\n","numLines":238,"startLine":1,"totalLines":238}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GLL3dbCfRx4je3WDY1B23v","type":"tool_result","content":"     1→/**\n     2→ * Unit tests for lib/trial-utils.ts — isValidFingerprint and clearTrialStatusCache.\n     3→ *\n     4→ * Covers acceptance criteria for Issue #922:\n     5→ * - Fingerprint validation rejects invalid inputs before calling /api/trial/init\n     6→ * - clearTrialStatusCache resets module cache so next useTrialStatus fetch is fresh\n     7→ *\n     8→ * @ref Issue #922\n     9→ */\n    10→\n    11→import { describe, it, expect, beforeEach, afterEach, vi } from \"vitest\";\n    12→\n    13→// ── isValidFingerprint ────────────────────────────────────────────────────────\n    14→\n    15→import { isValidFingerprint } from \"@/lib/trial-utils\";\n    16→\n    17→describe(\"isValidFingerprint\", () => {\n    18→  it(\"accepts a valid 64-character lowercase hex string\", () => {\n    19→    expect(isValidFingerprint(\"a\".repeat(64))).toBe(true);\n    20→  });\n    21→\n    22→  it(\"accepts mixed lowercase hex digits\", () => {\n    23→    expect(isValidFingerprint(\"0123456789abcdef\".repeat(4))).toBe(true);\n    24→  });\n    25→\n    26→  it(\"rejects a string shorter than 64 chars\", () => {\n    27→    expect(isValidFingerprint(\"a\".repeat(63))).toBe(false);\n    28→  });\n    29→\n    30→  it(\"rejects a string longer than 64 chars\", () => {\n    31→    expect(isValidFingerprint(\"a\".repeat(65))).toBe(false);\n    32→  });\n    33→\n    34→  it(\"rejects uppercase hex characters\", () => {\n    35→    expect(isValidFingerprint(\"A\".repeat(64))).toBe(false);\n    36→  });\n    37→\n    38→  it(\"rejects non-hex characters (e.g. 'g')\", () => {\n    39→    expect(isValidFingerprint(\"g\".repeat(64))).toBe(false);\n    40→  });\n    41→\n    42→  it(\"rejects an empty string\", () => {\n    43→    expect(isValidFingerprint(\"\")).toBe(false);\n    44→  });\n    45→});\n    46→\n    47→// ── clearTrialStatusCache ─────────────────────────────────────────────────────\n    48→// We test the cache-clearing contract by observing that after clearTrialStatusCache\n    49→// is called, a freshly imported cache has no stale data. The hook internals use a\n    50→// module-level variable; resetting it is the critical post-trial-init step in #922.\n    51→\n    52→describe(\"clearTrialStatusCache\", () => {\n    53→  beforeEach(() => {\n    54→    vi.resetModules();\n    55→  });\n    56→\n    57→  afterEach(() => {\n    58→    vi.restoreAllMocks();\n    59→  });\n    60→\n    61→  it(\"is exported from the useTrialStatus module\", async () => {\n    62→    const mod = await import(\"@/hooks/useTrialStatus\");\n    63→    expect(typeof mod.clearTrialStatusCache).toBe(\"function\");\n    64→  });\n    65→\n    66→  it(\"does not throw when called with no prior cache\", async () => {\n    67→    const { clearTrialStatusCache } = await import(\"@/hooks/useTrialStatus\");\n    68→    expect(() => clearTrialStatusCache()).not.toThrow();\n    69→  });\n    70→});\n    71→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8f0c11e7-f1f2-45f1-b28f-b520f037c3ce","uuid":"42eeffb6-e569-4542-a992-8d02d701740e","tool_use_result":{"type":"text","file":{"filePath":"/workspace/repo/development/frontend/src/__tests__/trial/trial-utils.test.ts","content":"/**\n * Unit tests for lib/trial-utils.ts — isValidFingerprint and clearTrialStatusCache.\n *\n * Covers acceptance criteria for Issue #922:\n * - Fingerprint validation rejects invalid inputs before calling /api/trial/init\n * - clearTrialStatusCache resets module cache so next useTrialStatus fetch is fresh\n *\n * @ref Issue #922\n */\n\nimport { describe, it, expect, beforeEach, afterEach, vi } from \"vitest\";\n\n// ── isValidFingerprint ────────────────────────────────────────────────────────\n\nimport { isValidFingerprint } from \"@/lib/trial-utils\";\n\ndescribe(\"isValidFingerprint\", () => {\n  it(\"accepts a valid 64-character lowercase hex string\", () => {\n    expect(isValidFingerprint(\"a\".repeat(64))).toBe(true);\n  });\n\n  it(\"accepts mixed lowercase hex digits\", () => {\n    expect(isValidFingerprint(\"0123456789abcdef\".repeat(4))).toBe(true);\n  });\n\n  it(\"rejects a string shorter than 64 chars\", () => {\n    expect(isValidFingerprint(\"a\".repeat(63))).toBe(false);\n  });\n\n  it(\"rejects a string longer than 64 chars\", () => {\n    expect(isValidFingerprint(\"a\".repeat(65))).toBe(false);\n  });\n\n  it(\"rejects uppercase hex characters\", () => {\n    expect(isValidFingerprint(\"A\".repeat(64))).toBe(false);\n  });\n\n  it(\"rejects non-hex characters (e.g. 'g')\", () => {\n    expect(isValidFingerprint(\"g\".repeat(64))).toBe(false);\n  });\n\n  it(\"rejects an empty string\", () => {\n    expect(isValidFingerprint(\"\")).toBe(false);\n  });\n});\n\n// ── clearTrialStatusCache ─────────────────────────────────────────────────────\n// We test the cache-clearing contract by observing that after clearTrialStatusCache\n// is called, a freshly imported cache has no stale data. The hook internals use a\n// module-level variable; resetting it is the critical post-trial-init step in #922.\n\ndescribe(\"clearTrialStatusCache\", () => {\n  beforeEach(() => {\n    vi.resetModules();\n  });\n\n  afterEach(() => {\n    vi.restoreAllMocks();\n  });\n\n  it(\"is exported from the useTrialStatus module\", async () => {\n    const mod = await import(\"@/hooks/useTrialStatus\");\n    expect(typeof mod.clearTrialStatusCache).toBe(\"function\");\n  });\n\n  it(\"does not throw when called with no prior cache\", async () => {\n    const { clearTrialStatusCache } = await import(\"@/hooks/useTrialStatus\");\n    expect(() => clearTrialStatusCache()).not.toThrow();\n  });\n});\n","numLines":71,"startLine":1,"totalLines":71}}}
