{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016bCmHXKtgEyHfeM48x8y1s","type":"tool_result","content":"     1→/**\n     2→ * Integration tests for POST /api/trial/status\n     3→ *\n     4→ * Covers:\n     5→ *  - Returns active status with remaining days for an existing trial\n     6→ *  - Auto-initializes trial when none exists (defense-in-depth fallback, #944)\n     7→ *  - Canceled Stripe customers receive an active trial (no blocking)\n     8→ *  - Returns correct status for expired trial\n     9→ *  - Returns correct status for converted trial\n    10→ *  - Invalid fingerprint returns 400\n    11→ *  - Missing fingerprint returns 400\n    12→ *  - Unauthenticated request returns 401\n    13→ *  - Rate limit returns 429\n    14→ *  - Redis failure falls through gracefully\n    15→ *\n    16→ * @see src/app/api/trial/status/route.ts\n    17→ * @ref Issue #944 (regression of #922)\n    18→ */\n    19→\n    20→import { describe, it, expect, beforeEach, vi } from \"vitest\";\n    21→import { NextRequest } from \"next/server\";\n    22→\n    23→// ── Mocks ─────────────────────────────────────────────────────────────────────\n    24→\n    25→const mockRedis = vi.hoisted(() => ({\n    26→  get: vi.fn(),\n    27→  set: vi.fn(),\n    28→}));\n    29→\n    30→vi.mock(\"@/lib/kv/redis-client\", () => ({\n    31→  getRedisClient: () => mockRedis,\n    32→}));\n    33→\n    34→const mockRateLimit = vi.hoisted(() => vi.fn(() => ({ success: true, remaining: 29 })));\n    35→\n    36→vi.mock(\"@/lib/rate-limit\", () => ({\n    37→  rateLimit: mockRateLimit,\n    38→}));\n    39→\n    40→vi.mock(\"@/lib/logger\", () => ({\n    41→  log: { debug: vi.fn(), info: vi.fn(), warn: vi.fn(), error: vi.fn() },\n    42→}));\n    43→\n    44→const mockRequireAuth = vi.fn();\n    45→vi.mock(\"@/lib/auth/require-auth\", () => ({\n    46→  requireAuth: (...args: unknown[]) => mockRequireAuth(...args),\n    47→}));\n    48→\n    49→// ── Import route handler after mocks ──────────────────────────────────────────\n    50→\n    51→import { POST } from \"@/app/api/trial/status/route\";\n    52→\n    53→// ── Helpers ───────────────────────────────────────────────────────────────────\n    54→\n    55→const VALID_FINGERPRINT = \"a\".repeat(64);\n    56→\n    57→function makeRequest(body: Record<string, unknown> = {}, token = \"valid-token\"): NextRequest {\n    58→  return new NextRequest(\"http://localhost:9653/api/trial/status\", {\n    59→    method: \"POST\",\n    60→    headers: {\n    61→      \"Content-Type\": \"application/json\",\n    62→      Authorization: `Bearer ${token}`,\n    63→      \"x-forwarded-for\": \"127.0.0.1\",\n    64→    },\n    65→    body: JSON.stringify(body),\n    66→  });\n    67→}\n    68→\n    69→function authOk() {\n    70→  mockRequireAuth.mockResolvedValue({ ok: true, user: { sub: \"google-sub-123\" } });\n    71→}\n    72→\n    73→function authFail() {\n    74→  mockRequireAuth.mockResolvedValue({\n    75→    ok: false,\n    76→    response: new Response(JSON.stringify({ error: \"unauthorized\" }), { status: 401 }),\n    77→  });\n    78→}\n    79→\n    80→/** Returns an ISO date N days ago. */\n    81→function daysAgo(n: number): string {\n    82→  const d = new Date();\n    83→  d.setDate(d.getDate() - n);\n    84→  return d.toISOString();\n    85→}\n    86→\n    87→// ── Tests ──────────────────────────────────────────────────────────────────────\n    88→\n    89→describe(\"POST /api/trial/status\", () => {\n    90→  beforeEach(() => {\n    91→    vi.clearAllMocks();\n    92→    authOk();\n    93→  });\n    94→\n    95→  // ═══════════════════════════════════════════════════════════════════════\n    96→  // Active trial — existing Redis record\n    97→  // ═══════════════════════════════════════════════════════════════════════\n    98→\n    99→  it(\"returns active status with remaining days for a new trial\", async () => {\n   100→    const startDate = daysAgo(0); // started today\n   101→    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate }));\n   102→\n   103→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   104→    const body = await res.json();\n   105→\n   106→    expect(res.status).toBe(200);\n   107→    expect(body.status).toBe(\"active\");\n   108→    expect(body.remainingDays).toBe(30);\n   109→    // Redis set should NOT be called — trial already exists\n   110→    expect(mockRedis.set).not.toHaveBeenCalled();\n   111→  });\n   112→\n   113→  it(\"returns correct remaining days based on start date\", async () => {\n   114→    const startDate = daysAgo(5); // 5 days into 30-day trial\n   115→    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate }));\n   116→\n   117→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   118→    const body = await res.json();\n   119→\n   120→    expect(res.status).toBe(200);\n   121→    expect(body.status).toBe(\"active\");\n   122→    expect(body.remainingDays).toBe(25);\n   123→  });\n   124→\n   125→  // ═══════════════════════════════════════════════════════════════════════\n   126→  // Defense-in-depth: auto-init when trial is missing (#944)\n   127→  // ═══════════════════════════════════════════════════════════════════════\n   128→\n   129→  it(\"auto-initializes trial when none exists and returns active status\", async () => {\n   130→    // First GET (getTrial check) returns null — trial not found\n   131→    mockRedis.get.mockResolvedValueOnce(null);\n   132→    // Second GET (inside initTrial's getTrial check) also returns null\n   133→    mockRedis.get.mockResolvedValueOnce(null);\n   134→    // Redis SET succeeds for the new trial\n   135→    mockRedis.set.mockResolvedValueOnce(\"OK\");\n   136→\n   137→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   138→    const body = await res.json();\n   139→\n   140→    expect(res.status).toBe(200);\n   141→    expect(body.status).toBe(\"active\");\n   142→    expect(body.remainingDays).toBe(30);\n   143→    // Trial was written to Redis\n   144→    expect(mockRedis.set).toHaveBeenCalledOnce();\n   145→    expect(mockRedis.set).toHaveBeenCalledWith(\n   146→      `trial:${VALID_FINGERPRINT}`,\n   147→      expect.any(String),\n   148→      \"EX\",\n   149→      expect.any(Number),\n   150→    );\n   151→  });\n   152→\n   153→  it(\"auto-init is idempotent: if trial exists between getTrial and initTrial, preserves original\", async () => {\n   154→    const originalStartDate = \"2026-03-01T00:00:00.000Z\";\n   155→    // getTrial returns null (missed by callback), but initTrial finds it (race condition resolved)\n   156→    mockRedis.get.mockResolvedValueOnce(null); // getTrial in status route: not found\n   157→    mockRedis.get.mockResolvedValueOnce( // getTrial inside initTrial: found (another init already ran)\n   158→      JSON.stringify({ startDate: originalStartDate }),\n   159→    );\n   160→\n   161→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   162→    const body = await res.json();\n   163→\n   164→    expect(res.status).toBe(200);\n   165→    expect(body.status).toBe(\"active\");\n   166→    // No new Redis write — initTrial returned the existing record\n   167→    expect(mockRedis.set).not.toHaveBeenCalled();\n   168→  });\n   169→\n   170→  // ═══════════════════════════════════════════════════════════════════════\n   171→  // Canceled Stripe customers can start a trial (#944 AC)\n   172→  // ═══════════════════════════════════════════════════════════════════════\n   173→\n   174→  it(\"returns active trial for a user with a canceled Stripe subscription\", async () => {\n   175→    // The status route does NOT check Stripe status — no entitlement lookup occurs here.\n   176→    // A user with stripeStatus:canceled has no trial in Redis; the route auto-inits it.\n   177→    mockRedis.get.mockResolvedValueOnce(null); // getTrial: not found\n   178→    mockRedis.get.mockResolvedValueOnce(null); // getTrial inside initTrial: also not found\n   179→    mockRedis.set.mockResolvedValueOnce(\"OK\"); // initTrial writes new trial\n   180→\n   181→    // Auth user simulates a canceled Stripe customer — no difference at this route level\n   182→    mockRequireAuth.mockResolvedValue({\n   183→      ok: true,\n   184→      user: { sub: \"google-sub-canceled-stripe\", email: \"user@example.com\" },\n   185→    });\n   186→\n   187→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   188→    const body = await res.json();\n   189→\n   190→    expect(res.status).toBe(200);\n   191→    expect(body.status).toBe(\"active\");\n   192→    expect(body.remainingDays).toBe(30);\n   193→  });\n   194→\n   195→  // ═══════════════════════════════════════════════════════════════════════\n   196→  // Expired trial\n   197→  // ═══════════════════════════════════════════════════════════════════════\n   198→\n   199→  it(\"returns expired status for trial started 31 days ago\", async () => {\n   200→    const startDate = daysAgo(31); // 31 days ago — beyond the 30-day trial\n   201→    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate }));\n   202→\n   203→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   204→    const body = await res.json();\n   205→\n   206→    expect(res.status).toBe(200);\n   207→    expect(body.status).toBe(\"expired\");\n   208→    expect(body.remainingDays).toBe(0);\n   209→  });\n   210→\n   211→  // ═══════════════════════════════════════════════════════════════════════\n   212→  // Converted trial\n   213→  // ═══════════════════════════════════════════════════════════════════════\n   214→\n   215→  it(\"returns converted status for a trial with a convertedDate\", async () => {\n   216→    const startDate = daysAgo(10);\n   217→    const convertedDate = daysAgo(2);\n   218→    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate, convertedDate }));\n   219→\n   220→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   221→    const body = await res.json();\n   222→\n   223→    expect(res.status).toBe(200);\n   224→    expect(body.status).toBe(\"converted\");\n   225→    expect(body.remainingDays).toBe(0);\n   226→    expect(body.convertedDate).toBe(convertedDate);\n   227→  });\n   228→\n   229→  // ═══════════════════════════════════════════════════════════════════════\n   230→  // Unauthenticated request blocked\n   231→  // ═══════════════════════════════════════════════════════════════════════\n   232→\n   233→  it(\"returns 401 for unauthenticated request\", async () => {\n   234→    authFail();\n   235→\n   236→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }, \"\"));\n   237→    expect(res.status).toBe(401);\n   238→  });\n   239→\n   240→  // ═══════════════════════════════════════════════════════════════════════\n   241→  // Input validation\n   242→  // ═══════════════════════════════════════════════════════════════════════\n   243→\n   244→  it(\"returns 400 for invalid fingerprint (too short)\", async () => {\n   245→    const res = await POST(makeRequest({ fingerprint: \"abc123\" }));\n   246→    const body = await res.json();\n   247→\n   248→    expect(res.status).toBe(400);\n   249→    expect(body.error).toBe(\"invalid_fingerprint\");\n   250→  });\n   251→\n   252→  it(\"returns 400 for missing fingerprint field\", async () => {\n   253→    const res = await POST(makeRequest({ notAFingerprint: \"whatever\" }));\n   254→    const body = await res.json();\n   255→\n   256→    expect(res.status).toBe(400);\n   257→    expect(body.error).toBe(\"invalid_body\");\n   258→  });\n   259→\n   260→  it(\"returns 400 for empty body\", async () => {\n   261→    const req = new NextRequest(\"http://localhost:9653/api/trial/status\", {\n   262→      method: \"POST\",\n   263→      headers: {\n   264→        \"Content-Type\": \"application/json\",\n   265→        Authorization: \"Bearer valid-token\",\n   266→        \"x-forwarded-for\": \"127.0.0.1\",\n   267→      },\n   268→      body: \"not-valid-json\",\n   269→    });\n   270→\n   271→    const res = await POST(req);\n   272→    expect(res.status).toBe(400);\n   273→  });\n   274→\n   275→  // ═══════════════════════════════════════════════════════════════════════\n   276→  // Rate limiting\n   277→  // ═══════════════════════════════════════════════════════════════════════\n   278→\n   279→  it(\"returns 429 when rate limit is exceeded\", async () => {\n   280→    mockRateLimit.mockReturnValueOnce({ success: false, remaining: 0 });\n   281→\n   282→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   283→    const body = await res.json();\n   284→\n   285→    expect(res.status).toBe(429);\n   286→    expect(body.error).toBe(\"rate_limited\");\n   287→  });\n   288→\n   289→  // ═══════════════════════════════════════════════════════════════════════\n   290→  // Cache-Control header\n   291→  // ═══════════════════════════════════════════════════════════════════════\n   292→\n   293→  it(\"response includes Cache-Control: no-store\", async () => {\n   294→    const startDate = daysAgo(0);\n   295→    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate }));\n   296→\n   297→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   298→\n   299→    expect(res.headers.get(\"Cache-Control\")).toBe(\"no-store\");\n   300→  });\n   301→\n   302→  // ═══════════════════════════════════════════════════════════════════════\n   303→  // Auto-init failure: Redis unavailable\n   304→  // ═══════════════════════════════════════════════════════════════════════\n   305→\n   306→  it(\"returns none status when both getTrial and auto-init fail due to Redis error\", async () => {\n   307→    // getTrial fails — Redis error\n   308→    mockRedis.get.mockRejectedValueOnce(new Error(\"Redis unavailable\"));\n   309→\n   310→    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n   311→    const body = await res.json();\n   312→\n   313→    // getTrial error is caught and returns null, then initTrial is called\n   314→    // but the outer try-catch wraps both; status depends on implementation\n   315→    expect([200, 500]).toContain(res.status);\n   316→    if (res.status === 200) {\n   317→      // If auto-init also fails, should return \"none\"\n   318→      expect([\"none\", \"active\"]).toContain(body.status);\n   319→    }\n   320→  });\n   321→});\n   322→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8f0c11e7-f1f2-45f1-b28f-b520f037c3ce","uuid":"b0f626d3-09df-419a-a4d1-a1fa076a2c8d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/repo/development/frontend/src/__tests__/trial/trial-status-route.test.ts","content":"/**\n * Integration tests for POST /api/trial/status\n *\n * Covers:\n *  - Returns active status with remaining days for an existing trial\n *  - Auto-initializes trial when none exists (defense-in-depth fallback, #944)\n *  - Canceled Stripe customers receive an active trial (no blocking)\n *  - Returns correct status for expired trial\n *  - Returns correct status for converted trial\n *  - Invalid fingerprint returns 400\n *  - Missing fingerprint returns 400\n *  - Unauthenticated request returns 401\n *  - Rate limit returns 429\n *  - Redis failure falls through gracefully\n *\n * @see src/app/api/trial/status/route.ts\n * @ref Issue #944 (regression of #922)\n */\n\nimport { describe, it, expect, beforeEach, vi } from \"vitest\";\nimport { NextRequest } from \"next/server\";\n\n// ── Mocks ─────────────────────────────────────────────────────────────────────\n\nconst mockRedis = vi.hoisted(() => ({\n  get: vi.fn(),\n  set: vi.fn(),\n}));\n\nvi.mock(\"@/lib/kv/redis-client\", () => ({\n  getRedisClient: () => mockRedis,\n}));\n\nconst mockRateLimit = vi.hoisted(() => vi.fn(() => ({ success: true, remaining: 29 })));\n\nvi.mock(\"@/lib/rate-limit\", () => ({\n  rateLimit: mockRateLimit,\n}));\n\nvi.mock(\"@/lib/logger\", () => ({\n  log: { debug: vi.fn(), info: vi.fn(), warn: vi.fn(), error: vi.fn() },\n}));\n\nconst mockRequireAuth = vi.fn();\nvi.mock(\"@/lib/auth/require-auth\", () => ({\n  requireAuth: (...args: unknown[]) => mockRequireAuth(...args),\n}));\n\n// ── Import route handler after mocks ──────────────────────────────────────────\n\nimport { POST } from \"@/app/api/trial/status/route\";\n\n// ── Helpers ───────────────────────────────────────────────────────────────────\n\nconst VALID_FINGERPRINT = \"a\".repeat(64);\n\nfunction makeRequest(body: Record<string, unknown> = {}, token = \"valid-token\"): NextRequest {\n  return new NextRequest(\"http://localhost:9653/api/trial/status\", {\n    method: \"POST\",\n    headers: {\n      \"Content-Type\": \"application/json\",\n      Authorization: `Bearer ${token}`,\n      \"x-forwarded-for\": \"127.0.0.1\",\n    },\n    body: JSON.stringify(body),\n  });\n}\n\nfunction authOk() {\n  mockRequireAuth.mockResolvedValue({ ok: true, user: { sub: \"google-sub-123\" } });\n}\n\nfunction authFail() {\n  mockRequireAuth.mockResolvedValue({\n    ok: false,\n    response: new Response(JSON.stringify({ error: \"unauthorized\" }), { status: 401 }),\n  });\n}\n\n/** Returns an ISO date N days ago. */\nfunction daysAgo(n: number): string {\n  const d = new Date();\n  d.setDate(d.getDate() - n);\n  return d.toISOString();\n}\n\n// ── Tests ──────────────────────────────────────────────────────────────────────\n\ndescribe(\"POST /api/trial/status\", () => {\n  beforeEach(() => {\n    vi.clearAllMocks();\n    authOk();\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Active trial — existing Redis record\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns active status with remaining days for a new trial\", async () => {\n    const startDate = daysAgo(0); // started today\n    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate }));\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(200);\n    expect(body.status).toBe(\"active\");\n    expect(body.remainingDays).toBe(30);\n    // Redis set should NOT be called — trial already exists\n    expect(mockRedis.set).not.toHaveBeenCalled();\n  });\n\n  it(\"returns correct remaining days based on start date\", async () => {\n    const startDate = daysAgo(5); // 5 days into 30-day trial\n    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate }));\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(200);\n    expect(body.status).toBe(\"active\");\n    expect(body.remainingDays).toBe(25);\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Defense-in-depth: auto-init when trial is missing (#944)\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"auto-initializes trial when none exists and returns active status\", async () => {\n    // First GET (getTrial check) returns null — trial not found\n    mockRedis.get.mockResolvedValueOnce(null);\n    // Second GET (inside initTrial's getTrial check) also returns null\n    mockRedis.get.mockResolvedValueOnce(null);\n    // Redis SET succeeds for the new trial\n    mockRedis.set.mockResolvedValueOnce(\"OK\");\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(200);\n    expect(body.status).toBe(\"active\");\n    expect(body.remainingDays).toBe(30);\n    // Trial was written to Redis\n    expect(mockRedis.set).toHaveBeenCalledOnce();\n    expect(mockRedis.set).toHaveBeenCalledWith(\n      `trial:${VALID_FINGERPRINT}`,\n      expect.any(String),\n      \"EX\",\n      expect.any(Number),\n    );\n  });\n\n  it(\"auto-init is idempotent: if trial exists between getTrial and initTrial, preserves original\", async () => {\n    const originalStartDate = \"2026-03-01T00:00:00.000Z\";\n    // getTrial returns null (missed by callback), but initTrial finds it (race condition resolved)\n    mockRedis.get.mockResolvedValueOnce(null); // getTrial in status route: not found\n    mockRedis.get.mockResolvedValueOnce( // getTrial inside initTrial: found (another init already ran)\n      JSON.stringify({ startDate: originalStartDate }),\n    );\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(200);\n    expect(body.status).toBe(\"active\");\n    // No new Redis write — initTrial returned the existing record\n    expect(mockRedis.set).not.toHaveBeenCalled();\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Canceled Stripe customers can start a trial (#944 AC)\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns active trial for a user with a canceled Stripe subscription\", async () => {\n    // The status route does NOT check Stripe status — no entitlement lookup occurs here.\n    // A user with stripeStatus:canceled has no trial in Redis; the route auto-inits it.\n    mockRedis.get.mockResolvedValueOnce(null); // getTrial: not found\n    mockRedis.get.mockResolvedValueOnce(null); // getTrial inside initTrial: also not found\n    mockRedis.set.mockResolvedValueOnce(\"OK\"); // initTrial writes new trial\n\n    // Auth user simulates a canceled Stripe customer — no difference at this route level\n    mockRequireAuth.mockResolvedValue({\n      ok: true,\n      user: { sub: \"google-sub-canceled-stripe\", email: \"user@example.com\" },\n    });\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(200);\n    expect(body.status).toBe(\"active\");\n    expect(body.remainingDays).toBe(30);\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Expired trial\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns expired status for trial started 31 days ago\", async () => {\n    const startDate = daysAgo(31); // 31 days ago — beyond the 30-day trial\n    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate }));\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(200);\n    expect(body.status).toBe(\"expired\");\n    expect(body.remainingDays).toBe(0);\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Converted trial\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns converted status for a trial with a convertedDate\", async () => {\n    const startDate = daysAgo(10);\n    const convertedDate = daysAgo(2);\n    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate, convertedDate }));\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(200);\n    expect(body.status).toBe(\"converted\");\n    expect(body.remainingDays).toBe(0);\n    expect(body.convertedDate).toBe(convertedDate);\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Unauthenticated request blocked\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns 401 for unauthenticated request\", async () => {\n    authFail();\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }, \"\"));\n    expect(res.status).toBe(401);\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Input validation\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns 400 for invalid fingerprint (too short)\", async () => {\n    const res = await POST(makeRequest({ fingerprint: \"abc123\" }));\n    const body = await res.json();\n\n    expect(res.status).toBe(400);\n    expect(body.error).toBe(\"invalid_fingerprint\");\n  });\n\n  it(\"returns 400 for missing fingerprint field\", async () => {\n    const res = await POST(makeRequest({ notAFingerprint: \"whatever\" }));\n    const body = await res.json();\n\n    expect(res.status).toBe(400);\n    expect(body.error).toBe(\"invalid_body\");\n  });\n\n  it(\"returns 400 for empty body\", async () => {\n    const req = new NextRequest(\"http://localhost:9653/api/trial/status\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: \"Bearer valid-token\",\n        \"x-forwarded-for\": \"127.0.0.1\",\n      },\n      body: \"not-valid-json\",\n    });\n\n    const res = await POST(req);\n    expect(res.status).toBe(400);\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Rate limiting\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns 429 when rate limit is exceeded\", async () => {\n    mockRateLimit.mockReturnValueOnce({ success: false, remaining: 0 });\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    expect(res.status).toBe(429);\n    expect(body.error).toBe(\"rate_limited\");\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Cache-Control header\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"response includes Cache-Control: no-store\", async () => {\n    const startDate = daysAgo(0);\n    mockRedis.get.mockResolvedValueOnce(JSON.stringify({ startDate }));\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n\n    expect(res.headers.get(\"Cache-Control\")).toBe(\"no-store\");\n  });\n\n  // ═══════════════════════════════════════════════════════════════════════\n  // Auto-init failure: Redis unavailable\n  // ═══════════════════════════════════════════════════════════════════════\n\n  it(\"returns none status when both getTrial and auto-init fail due to Redis error\", async () => {\n    // getTrial fails — Redis error\n    mockRedis.get.mockRejectedValueOnce(new Error(\"Redis unavailable\"));\n\n    const res = await POST(makeRequest({ fingerprint: VALID_FINGERPRINT }));\n    const body = await res.json();\n\n    // getTrial error is caught and returns null, then initTrial is called\n    // but the outer try-catch wraps both; status depends on implementation\n    expect([200, 500]).toContain(res.status);\n    if (res.status === 200) {\n      // If auto-init also fails, should return \"none\"\n      expect([\"none\", \"active\"]).toContain(body.status);\n    }\n  });\n});\n","numLines":322,"startLine":1,"totalLines":322}}}
