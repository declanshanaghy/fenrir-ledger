# Secrets - NEVER commit
.env
*.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/

# Node/Frontend
node_modules/

# Next.js
.next/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing
coverage/
test-results/
playwright-report/
.playwright-mcp/
.playwright-cli/
.vercel
logs/

# Temp files (for parallel agent development)
tmp/
development/frontend/.claude/

# Lock files (ephemeral)
*.lock

# Agent worktrees (ephemeral, cleaned up after chain completion)
.claude/worktrees/
.claire/


# doc-sync run artifacts (ephemeral, coordinator reads then discards)
.sync-report.md

# Stray agent artifacts (safety net — agents should write to tmp/)
development/*.log
development/security-audit-*.png
development/console-*.log
development/network-requests-*.log

# Auto-generated session artifacts
TOOLS.md
.condense-report.md
